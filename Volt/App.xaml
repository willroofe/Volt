<Application x:Class="Volt.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:Volt"
>
    <Application.Resources>
        <!-- Light theme defaults (overwritten at runtime by ThemeManager) -->
        <SolidColorBrush x:Key="ThemeChromeBrush" Color="#E8E8E8"/>
        <SolidColorBrush x:Key="ThemeBorderBrush" Color="#D0D0D0"/>
        <SolidColorBrush x:Key="ThemeContentBg" Color="White"/>
        <SolidColorBrush x:Key="ThemeTextFg" Color="#111111"/>
        <SolidColorBrush x:Key="ThemeTextFgStrong" Color="#222222"/>
        <SolidColorBrush x:Key="ThemeTextFgMuted" Color="#888888"/>
        <SolidColorBrush x:Key="ThemeButtonFg" Color="#333333"/>
        <SolidColorBrush x:Key="ThemeButtonHover" Color="#D0D0D0"/>
        <SolidColorBrush x:Key="ThemeMenuPopupBg" Color="White"/>
        <SolidColorBrush x:Key="ThemeMenuPopupBorder" Color="#D0D0D0"/>
        <SolidColorBrush x:Key="ThemeMenuItemHover" Color="#E0E0E0"/>
        <SolidColorBrush x:Key="ThemeNavBg" Color="#F0F0F0"/>
        <SolidColorBrush x:Key="ThemeNavActive" Color="#D8D8D8"/>
        <SolidColorBrush x:Key="ThemeNavHover" Color="#E0E0E0"/>
        <SolidColorBrush x:Key="ThemeScrollBg" Color="#E0E0E0"/>
        <SolidColorBrush x:Key="ThemeScrollThumb" Color="#C0C0C0"/>
        <SolidColorBrush x:Key="ThemeScrollThumbHover" Color="#A0A0A0"/>
        <SolidColorBrush x:Key="ThemeTabBarBg" Color="#E0E0E0"/>
        <SolidColorBrush x:Key="ThemeTabActive" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="ThemeTabActiveSecondary" Color="#E8E8F0"/>
        <SolidColorBrush x:Key="ThemeTabInactive" Color="#D8D8D8"/>
        <SolidColorBrush x:Key="ThemeTabHover" Color="#EBEBEB"/>
        <SolidColorBrush x:Key="ThemeTabBorder" Color="#D0D0D0"/>
        <SolidColorBrush x:Key="ThemeExplorerBg" Color="#F0F0F0"/>
        <SolidColorBrush x:Key="ThemeExplorerHeaderBg" Color="#E8E8E8"/>
        <SolidColorBrush x:Key="ThemeExplorerHeaderFg" Color="#888888"/>
        <SolidColorBrush x:Key="ThemeExplorerItemHover" Color="#E0E0E0"/>
        <SolidColorBrush x:Key="ThemeExplorerItemSelected" Color="#D0D0D0"/>
        <SolidColorBrush x:Key="ThemeExplorerDropTarget" Color="#B8D4E8"/>
        <SolidColorBrush x:Key="ThemeInputSelection" Color="#80339900"/>
        <SolidColorBrush x:Key="ThemeIconPrimary" Color="#111111"/>
        <SolidColorBrush x:Key="ThemeIconSecondary" Color="#888888"/>
        <SolidColorBrush x:Key="ThemeIconAccent" Color="#222222"/>

        <!-- Codicon font: use {x:Static local:Codicons.Font} — single-string pack URIs are invalid for FontFamily. -->

        <!-- Theme-invariant overlay for modal dimming (like close-button red #E81123) -->
        <SolidColorBrush x:Key="ThemeOverlayBg" Color="#80000000"/>

        <!-- Title bar buttons (shared by MainWindow and SettingsWindow) -->
        <Style x:Key="TitleBarButton" TargetType="Button">
            <Setter Property="WindowChrome.IsHitTestVisibleInChrome" Value="True"/>
            <Setter Property="Width" Value="46"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource ThemeButtonFg}"/>
            <Setter Property="FontFamily" Value="Segoe MDL2 Assets"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource ThemeButtonHover}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="CloseButton" TargetType="Button" BasedOn="{StaticResource TitleBarButton}">
            <Setter Property="Content" Value="&#xE8BB;"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#E81123"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Scrollbar thumb (shared by both orientations) -->
        <Style x:Key="ScrollBarThumb" TargetType="Thumb">
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="IsTabStop" Value="False"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Thumb">
                        <Border x:Name="Bd" Background="{DynamicResource ThemeScrollThumb}"
                                CornerRadius="3"/>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background"
                                        Value="{DynamicResource ThemeScrollThumbHover}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Invisible repeat button for the track area above/below the thumb -->
        <Style x:Key="ScrollBarTrackButton" TargetType="RepeatButton">
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="IsTabStop" Value="False"/>
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RepeatButton">
                        <Border Background="Transparent"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Arrow repeat button (top/bottom/left/right) -->
        <Style x:Key="ScrollBarArrowButton" TargetType="RepeatButton">
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="IsTabStop" Value="False"/>
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="FontFamily" Value="{x:Static local:Codicons.Font}"/>
            <Setter Property="Foreground" Value="{DynamicResource ThemeTextFgMuted}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RepeatButton">
                        <Border x:Name="Bd" Background="{DynamicResource ThemeScrollBg}" CornerRadius="3">
                            <TextBlock Text="{TemplateBinding Content}"
                                       FontFamily="{TemplateBinding FontFamily}"
                                       FontSize="{TemplateBinding FontSize}"
                                       Foreground="{TemplateBinding Foreground}"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background"
                                        Value="{DynamicResource ThemeScrollThumb}"/>
                                <Setter Property="Foreground"
                                        Value="{DynamicResource ThemeTextFg}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background"
                                        Value="{DynamicResource ThemeScrollThumbHover}"/>
                                <Setter Property="Foreground"
                                        Value="{DynamicResource ThemeTextFg}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Vertical ScrollBar -->
        <ControlTemplate x:Key="VerticalScrollBar" TargetType="ScrollBar">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Border Grid.RowSpan="3" Background="{DynamicResource ThemeScrollBg}"/>
                <RepeatButton Grid.Row="0" Style="{StaticResource ScrollBarArrowButton}"
                              Height="14" Command="ScrollBar.LineUpCommand"
                              Content="&#xEAB7;" FontSize="8"/>
                <Track Grid.Row="1" x:Name="PART_Track" IsDirectionReversed="True">
                    <Track.DecreaseRepeatButton>
                        <RepeatButton Style="{StaticResource ScrollBarTrackButton}"
                                      Command="ScrollBar.PageUpCommand"/>
                    </Track.DecreaseRepeatButton>
                    <Track.Thumb>
                        <Thumb Style="{StaticResource ScrollBarThumb}"
                               Margin="2"/>
                    </Track.Thumb>
                    <Track.IncreaseRepeatButton>
                        <RepeatButton Style="{StaticResource ScrollBarTrackButton}"
                                      Command="ScrollBar.PageDownCommand"/>
                    </Track.IncreaseRepeatButton>
                </Track>
                <RepeatButton Grid.Row="2" Style="{StaticResource ScrollBarArrowButton}"
                              Height="14" Command="ScrollBar.LineDownCommand"
                              Content="&#xEAB4;" FontSize="8"/>
            </Grid>
        </ControlTemplate>

        <!-- Horizontal ScrollBar -->
        <ControlTemplate x:Key="HorizontalScrollBar" TargetType="ScrollBar">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Border Grid.ColumnSpan="3" Background="{DynamicResource ThemeScrollBg}"/>
                <RepeatButton Grid.Column="0" Style="{StaticResource ScrollBarArrowButton}"
                              Width="14" Command="ScrollBar.LineLeftCommand"
                              Content="&#xEAB5;" FontSize="8"/>
                <Track Grid.Column="1" x:Name="PART_Track">
                    <Track.DecreaseRepeatButton>
                        <RepeatButton Style="{StaticResource ScrollBarTrackButton}"
                                      Command="ScrollBar.PageLeftCommand"/>
                    </Track.DecreaseRepeatButton>
                    <Track.Thumb>
                        <Thumb Style="{StaticResource ScrollBarThumb}"
                               Margin="2"/>
                    </Track.Thumb>
                    <Track.IncreaseRepeatButton>
                        <RepeatButton Style="{StaticResource ScrollBarTrackButton}"
                                      Command="ScrollBar.PageRightCommand"/>
                    </Track.IncreaseRepeatButton>
                </Track>
                <RepeatButton Grid.Column="2" Style="{StaticResource ScrollBarArrowButton}"
                              Width="14" Command="ScrollBar.LineRightCommand"
                              Content="&#xEAB6;" FontSize="8"/>
            </Grid>
        </ControlTemplate>

        <!-- ScrollBar style that picks the right template by orientation -->
        <Style TargetType="ScrollBar">
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Style.Triggers>
                <Trigger Property="Orientation" Value="Vertical">
                    <Setter Property="Width" Value="14"/>
                    <Setter Property="Template" Value="{StaticResource VerticalScrollBar}"/>
                </Trigger>
                <Trigger Property="Orientation" Value="Horizontal">
                    <Setter Property="Height" Value="14"/>
                    <Setter Property="Template" Value="{StaticResource HorizontalScrollBar}"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <!-- Tab close button (icon button on tab headers) -->
        <Style x:Key="TabCloseButton" TargetType="Button">
            <Setter Property="Content" Value="&#xEAB8;"/>
            <Setter Property="FontFamily" Value="{x:Static local:Codicons.Font}"/>
            <Setter Property="FontSize" Value="8"/>
            <Setter Property="Width" Value="20"/>
            <Setter Property="Height" Value="20"/>
            <Setter Property="Margin" Value="0,0,4,0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Foreground" Value="{DynamicResource ThemeTextFgMuted}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="Transparent" CornerRadius="3">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource ThemeButtonHover}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Themed nav button (icon buttons used in FindBar) -->
        <Style x:Key="FindBarNavButton" TargetType="Button">
            <Setter Property="Width" Value="28"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="Margin" Value="2,0,0,0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource ThemeTextFg}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" CornerRadius="3"
                                Background="Transparent"
                                BorderThickness="1"
                                BorderBrush="{DynamicResource ThemeMenuPopupBorder}"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{DynamicResource ThemeButtonHover}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{DynamicResource ThemeMenuItemHover}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Themed text button (Replace / Replace All in FindBar) -->
        <Style x:Key="FindBarTextButton" TargetType="Button">
            <Setter Property="Height" Value="28"/>
            <Setter Property="Margin" Value="6,0,0,0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource ThemeTextFg}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" CornerRadius="3"
                                Background="Transparent"
                                BorderThickness="1"
                                BorderBrush="{DynamicResource ThemeMenuPopupBorder}"
                                Padding="10,0"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{DynamicResource ThemeButtonHover}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{DynamicResource ThemeMenuItemHover}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Match case toggle button style -->
        <Style x:Key="MatchCaseButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground" Value="{DynamicResource ThemeTextFgMuted}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" CornerRadius="3"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{DynamicResource ThemeButtonHover}"/>
                            </Trigger>
                            <Trigger Property="Tag" Value="Active">
                                <Setter TargetName="border" Property="Background" Value="{DynamicResource ThemeButtonHover}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Foreground" Value="{DynamicResource ThemeButtonFg}"/>
                </Trigger>
                <Trigger Property="Tag" Value="Active">
                    <Setter Property="Foreground" Value="{DynamicResource ThemeButtonFg}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Themed dialog button (OK/Cancel in dialogs) -->
        <Style x:Key="DialogButton" TargetType="Button">
            <Setter Property="MinWidth" Value="80"/>
            <Setter Property="Margin" Value="4,0,0,0"/>
            <Setter Property="Padding" Value="12,6,12,6"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="{DynamicResource ThemeButtonFg}"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{DynamicResource ThemeContentBg}"
                                BorderBrush="{DynamicResource ThemeMenuPopupBorder}"
                                BorderThickness="1" CornerRadius="3"
                                Padding="{TemplateBinding Padding}"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource ThemeButtonHover}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Rounded text box (replace input in FindBar) -->
        <Style x:Key="RoundedTextBox" TargetType="TextBox">
            <Setter Property="CaretBrush" Value="{DynamicResource ThemeTextFg}"/>
            <Setter Property="SelectionBrush" Value="{DynamicResource ThemeInputSelection}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border CornerRadius="3" BorderThickness="1"
                                BorderBrush="{DynamicResource ThemeMenuPopupBorder}"
                                Background="Transparent"
                                SnapsToDevicePixels="True">
                            <ScrollViewer x:Name="PART_ContentHost"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Themed separator for menus -->
        <Style x:Key="{x:Static MenuItem.SeparatorStyleKey}" TargetType="Separator">
            <Setter Property="Margin" Value="0,2"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Separator">
                        <Border Height="1" Background="{DynamicResource ThemeMenuPopupBorder}"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Themed context menu item style (defined before ContextMenu so it can be referenced) -->
        <Style x:Key="ThemedContextMenuItem" TargetType="MenuItem">
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="{DynamicResource ThemeTextFg}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="MenuItem">
                        <Grid>
                            <Border x:Name="Bd" Background="Transparent"
                                    CornerRadius="4" Margin="4,1">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="28" SharedSizeGroup="Icon"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto" SharedSizeGroup="Shortcut"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <ContentPresenter Grid.Column="0" ContentSource="Icon"
                                                      HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"
                                                      Width="16" Height="16"/>
                                    <ContentPresenter Grid.Column="1" ContentSource="Header"
                                                      Margin="6,4,12,4"
                                                      VerticalAlignment="Center"
                                                      RecognizesAccessKey="True"/>
                                    <TextBlock Grid.Column="2" Text="{TemplateBinding InputGestureText}"
                                               Margin="0,4,8,4"
                                               VerticalAlignment="Center"
                                               Foreground="{DynamicResource ThemeTextFgMuted}"/>
                                    <!-- Submenu arrow -->
                                    <TextBlock x:Name="SubArrow" Grid.Column="3"
                                               Text="&#xEAB6;" FontFamily="{x:Static local:Codicons.Font}" FontSize="8"
                                               VerticalAlignment="Center" Margin="0,0,8,0"
                                               Foreground="{DynamicResource ThemeTextFgMuted}"
                                               Visibility="Collapsed"/>
                                </Grid>
                            </Border>
                            <!-- Submenu popup for items with children -->
                            <Popup x:Name="PART_Popup"
                                   IsOpen="{Binding IsSubmenuOpen, RelativeSource={RelativeSource TemplatedParent}}"
                                   Placement="Right"
                                   HorizontalOffset="-2"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   PopupAnimation="None">
                                <Border Background="{DynamicResource ThemeMenuPopupBg}"
                                        BorderBrush="{DynamicResource ThemeMenuPopupBorder}" BorderThickness="1"
                                        CornerRadius="3" Margin="0,0,6,6">
                                    <Border.Effect>
                                        <DropShadowEffect ShadowDepth="2" Opacity="0.4" BlurRadius="8"/>
                                    </Border.Effect>
                                    <StackPanel IsItemsHost="True" Margin="0,3"
                                                KeyboardNavigation.DirectionalNavigation="Cycle"
                                                Grid.IsSharedSizeScope="True"/>
                                </Border>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource ThemeMenuItemHover}"/>
                            </Trigger>
                            <Trigger Property="Role" Value="SubmenuHeader">
                                <Setter TargetName="SubArrow" Property="Visibility" Value="Visible"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Themed ContextMenu (right-click menus) -->
        <Style TargetType="ContextMenu">
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="{DynamicResource ThemeTextFg}"/>
            <Setter Property="HasDropShadow" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ContextMenu">
                        <Border Background="{DynamicResource ThemeMenuPopupBg}"
                                BorderBrush="{DynamicResource ThemeMenuPopupBorder}" BorderThickness="1"
                                CornerRadius="3" Margin="0,0,6,6">
                            <Border.Effect>
                                <DropShadowEffect ShadowDepth="2" Opacity="0.4" BlurRadius="8"/>
                            </Border.Effect>
                            <StackPanel IsItemsHost="True" Margin="0,3"
                                        KeyboardNavigation.DirectionalNavigation="Cycle"
                                        Grid.IsSharedSizeScope="True"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ScrollViewer with themed corner -->
        <ControlTemplate x:Key="ThemedScrollViewer" TargetType="ScrollViewer">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <ScrollContentPresenter x:Name="PART_ScrollContentPresenter"
                                        Grid.Column="0" Grid.Row="0"
                                        Content="{TemplateBinding Content}"
                                        ContentTemplate="{TemplateBinding ContentTemplate}"
                                        CanContentScroll="{TemplateBinding CanContentScroll}"/>
                <ScrollBar x:Name="PART_VerticalScrollBar"
                           Grid.Column="1" Grid.Row="0"
                           Orientation="Vertical"
                           Value="{TemplateBinding VerticalOffset}"
                           Maximum="{TemplateBinding ScrollableHeight}"
                           ViewportSize="{TemplateBinding ViewportHeight}"
                           Visibility="{TemplateBinding ComputedVerticalScrollBarVisibility}"/>
                <ScrollBar x:Name="PART_HorizontalScrollBar"
                           Grid.Column="0" Grid.Row="1"
                           Orientation="Horizontal"
                           Value="{TemplateBinding HorizontalOffset}"
                           Maximum="{TemplateBinding ScrollableWidth}"
                           ViewportSize="{TemplateBinding ViewportWidth}"
                           Visibility="{TemplateBinding ComputedHorizontalScrollBarVisibility}"/>
                <Rectangle Grid.Column="1" Grid.Row="1"
                           Fill="{DynamicResource ThemeScrollBg}"/>
            </Grid>
        </ControlTemplate>
    </Application.Resources>
</Application>
