{
  "name": "INI",
  "extensions": [".ini", ".cfg", ".conf"],
  "rules": [
    {
      "pattern": "[#;].*$",
      "scope": "comment"
    },
    {
      "pattern": "^\\s*\\[[^\\]]+\\]",
      "scope": "keyword"
    },
    {
      "pattern": "^[A-Za-z0-9_.-]+(?=\\s*[=:])",
      "scope": "hashkey"
    },
    {
      "pattern": "\"(?:\\\\.|[^\"\\\\])*\"|'(?:\\\\.|[^'\\\\])*'",
      "scope": "string"
    },
    {
      "pattern": "\\b(?:true|false|yes|no|on|off|null)\\b",
      "scope": "keyword"
    },
    {
      "pattern": "\\b-?\\d+(?:\\.\\d+)?\\b",
      "scope": "number"
    },
    {
      "pattern": "[=:]",
      "scope": "operator"
    }
  ]
}
