{
  "name": "Rust",
  "extensions": [".rs"],
  "blockComments": [
    {
      "start": "^\\s*/\\*(?!.*\\*/)",
      "end": "\\*/",
      "scope": "comment"
    }
  ],
  "rules": [
    {
      "pattern": "r#*\".*?\"#*|\"(?:\\\\.|[^\"\\\\])*\"|'(?:\\\\.|[^'\\\\])'",
      "scope": "string"
    },
    {
      "pattern": "/\\*.*?\\*/",
      "scope": "comment"
    },
    {
      "pattern": "//!.*$|///.*$|//.*$",
      "scope": "comment"
    },
    {
      "pattern": "\\b(?:as|async|await|become|box|break|const|continue|crate|do|dyn|else|enum|extern|false|final|fn|for|if|impl|in|let|loop|macro|match|mod|move|mut|override|priv|pub|ref|return|self|Self|static|struct|super|trait|true|try|type|typeof|unsafe|unsized|use|virtual|where|while|yield)\\b",
      "scope": "keyword"
    },
    {
      "pattern": "\\b(?:bool|char|f32|f64|i8|i16|i32|i64|i128|isize|str|String|u8|u16|u32|u64|u128|usize|Vec|Option|Result)\\b",
      "scope": "type"
    },
    {
      "pattern": "(?<=\\bfn\\s)[A-Za-z_][\\w]*",
      "scope": "function"
    },
    {
      "pattern": "\\b[A-Za-z_][\\w]*(?=!)",
      "scope": "function"
    },
    {
      "pattern": "\\b[A-Za-z_][\\w]*(?=\\s*\\()",
      "scope": "function"
    },
    {
      "pattern": "'[A-Za-z_][\\w]*",
      "scope": "variable"
    },
    {
      "pattern": "\\b(?:0[xX][0-9a-fA-F_]+|0[bB][01_]+|0[oO][0-7_]+|\\d[\\d_]*(?:\\.\\d[\\d_]*)?(?:[eE][+-]?\\d[\\d_]*)?(?:u8|u16|u32|u64|u128|usize|i8|i16|i32|i64|i128|isize|f32|f64)?)\\b",
      "scope": "number"
    },
    {
      "pattern": "=>|->|::|\\.\\.|\\.\\.=|==|!=|<=|>=|&&|\\|\\||[+\\-*/%=&|^~!<>?:.]",
      "scope": "operator"
    }
  ]
}
