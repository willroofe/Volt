{
  "name": "JavaScript",
  "extensions": [".js", ".mjs", ".cjs"],
  "blockComments": [
    {
      "start": "^\\s*/\\*(?!.*\\*/)",
      "end": "\\*/",
      "scope": "comment"
    }
  ],
  "interpolation": {
    "quotes": "`",
    "variablePattern": "\\$\\{[^}]*\\}",
    "escapePattern": "\\\\(?:[bfnrtv0\\\\'\"`]|x[0-9a-fA-F]{2}|u[0-9a-fA-F]{4}|u\\{[0-9a-fA-F]+\\}|.)"
  },
  "rules": [
    {
      "pattern": "(?:`(?:\\\\.|[^`\\\\])*`|\"(?:\\\\.|[^\"\\\\])*\"|'(?:\\\\.|[^'\\\\])*')",
      "scope": "string"
    },
    {
      "pattern": "/\\*.*?\\*/",
      "scope": "comment"
    },
    {
      "pattern": "//.*$",
      "scope": "comment"
    },
    {
      "pattern": "(?:^|[=(:,!&|?;{}\\[\\]])\\s*/(?:\\\\.|[^/\\\\\\n])+/[dgimsuvy]*",
      "scope": "regex"
    },
    {
      "pattern": "\\b(?:as|async|await|break|case|catch|class|const|continue|debugger|default|delete|do|else|export|extends|finally|for|from|function|get|if|import|in|instanceof|let|new|of|return|set|static|super|switch|this|throw|try|typeof|var|void|while|with|yield)\\b",
      "scope": "keyword"
    },
    {
      "pattern": "\\b(?:true|false|null|undefined|NaN|Infinity)\\b",
      "scope": "keyword"
    },
    {
      "pattern": "\\b(?:Array|ArrayBuffer|BigInt|Boolean|Date|Error|EvalError|Float32Array|Float64Array|Function|Generator|Int8Array|Int16Array|Int32Array|Intl|JSON|Map|Math|Number|Object|Promise|Proxy|RangeError|ReferenceError|Reflect|RegExp|Set|String|Symbol|SyntaxError|TypeError|Uint8Array|Uint8ClampedArray|Uint16Array|Uint32Array|URIError|WeakMap|WeakSet|WebAssembly|console|document|globalThis|module|process|require|window)\\b",
      "scope": "type"
    },
    {
      "pattern": "(?<=\\bfunction\\s)[$A-Za-z_][\\w$]*",
      "scope": "function"
    },
    {
      "pattern": "(?<=\\bclass\\s)[$A-Za-z_][\\w$]*",
      "scope": "type"
    },
    {
      "pattern": "\\b[$A-Za-z_][\\w$]*(?=\\s*=>)",
      "scope": "function"
    },
    {
      "pattern": "\\b[$A-Za-z_][\\w$]*(?=\\s*\\()",
      "scope": "function"
    },
    {
      "pattern": "(?<=\\.)[$A-Za-z_][\\w$]*(?=\\s*\\()",
      "scope": "function"
    },
    {
      "pattern": "\\b[$A-Za-z_][\\w$]*(?=\\s*:)",
      "scope": "hashkey"
    },
    {
      "pattern": "(?<=\\b(?:const|let|var)\\s)[$A-Za-z_][\\w$]*",
      "scope": "variable"
    },
    {
      "pattern": "\\b(?:0[xX][0-9a-fA-F_]+|0[bB][01_]+|0[oO][0-7_]+|\\d[\\d_]*(?:\\.\\d[\\d_]*)?(?:[eE][+-]?\\d[\\d_]*)?n?)\\b",
      "scope": "number"
    },
    {
      "pattern": "=>|\\+\\+|--|===|!==|==|!=|<=|>=|&&|\\|\\||\\?\\?|\\?\\.|\\*\\*|[+\\-*/%=&|^~!<>?:.]",
      "scope": "operator"
    }
  ]
}
