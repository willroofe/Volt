{
  "name": "TypeScript",
  "extensions": [".ts", ".tsx"],
  "blockComments": [
    {
      "start": "^\\s*/\\*(?!.*\\*/)",
      "end": "\\*/",
      "scope": "comment"
    }
  ],
  "interpolation": {
    "quotes": "`",
    "variablePattern": "\\$\\{[^}]*\\}",
    "escapePattern": "\\\\(?:[bfnrtv0\\\\'\"`]|x[0-9a-fA-F]{2}|u[0-9a-fA-F]{4}|u\\{[0-9a-fA-F]+\\}|.)"
  },
  "rules": [
    {
      "pattern": "(?:`(?:\\\\.|[^`\\\\])*`|\"(?:\\\\.|[^\"\\\\])*\"|'(?:\\\\.|[^'\\\\])*')",
      "scope": "string"
    },
    {
      "pattern": "/\\*.*?\\*/",
      "scope": "comment"
    },
    {
      "pattern": "//.*$",
      "scope": "comment"
    },
    {
      "pattern": "</?\\s*[A-Za-z][\\w.:-]*",
      "scope": "keyword"
    },
    {
      "pattern": "\\b(?:abstract|any|as|asserts|async|await|bigint|boolean|break|case|catch|class|const|continue|debugger|declare|default|delete|do|else|enum|export|extends|false|finally|for|from|function|get|if|implements|import|in|infer|instanceof|interface|is|keyof|let|module|namespace|never|new|null|number|object|of|package|private|protected|public|readonly|require|return|set|static|string|super|switch|symbol|this|throw|true|try|type|typeof|undefined|unique|unknown|var|void|while|with|yield)\\b",
      "scope": "keyword"
    },
    {
      "pattern": "\\b(?:Array|Boolean|Date|Error|Function|Map|Math|Number|Object|Promise|React|ReadonlyArray|Record|RegExp|Set|String|Symbol|console|document|window)\\b",
      "scope": "type"
    },
    {
      "pattern": "(?<=\\b(?:function|class|interface|type|enum)\\s)[$A-Za-z_][\\w$]*",
      "scope": "type"
    },
    {
      "pattern": "\\b[$A-Za-z_][\\w$]*(?=\\s*=>|\\s*\\()",
      "scope": "function"
    },
    {
      "pattern": "\\b[$A-Za-z_][\\w$]*(?=\\s*:)",
      "scope": "hashkey"
    },
    {
      "pattern": "\\b(?:0[xX][0-9a-fA-F_]+|0[bB][01_]+|0[oO][0-7_]+|\\d[\\d_]*(?:\\.\\d[\\d_]*)?(?:[eE][+-]?\\d[\\d_]*)?n?)\\b",
      "scope": "number"
    },
    {
      "pattern": "</?|/?>|=>|===|!==|==|!=|<=|>=|&&|\\|\\||\\?\\?|\\?\\.|[+\\-*/%=&|^~!<>?:.]",
      "scope": "operator"
    }
  ]
}
