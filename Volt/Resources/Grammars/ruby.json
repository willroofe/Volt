{
  "name": "Ruby",
  "extensions": [".rb", ".rake", ".gemspec"],
  "blockComments": [
    {
      "start": "^=begin\\b",
      "end": "^=end\\b",
      "scope": "comment"
    }
  ],
  "interpolation": {
    "quotes": "\"`",
    "variablePattern": "#\\{[^}]+\\}|[@$]?[A-Za-z_][\\w]*",
    "escapePattern": "\\\\(?:[abefnrstv\\\\'\"#]|x[0-9a-fA-F]{1,2}|u[0-9a-fA-F]{4}|.)"
  },
  "rules": [
    {
      "pattern": "\"(?:\\\\.|[^\"])*\"|'(?:\\\\.|[^'])*'|`(?:\\\\.|[^`])*`",
      "scope": "string"
    },
    {
      "pattern": "#.*$",
      "scope": "comment"
    },
    {
      "pattern": "\\b(?:BEGIN|END|alias|and|begin|break|case|class|def|defined\\?|do|else|elsif|end|ensure|false|for|if|in|module|next|nil|not|or|redo|rescue|retry|return|self|super|then|true|undef|unless|until|when|while|yield)\\b",
      "scope": "keyword"
    },
    {
      "pattern": "\\b(?:Array|Class|Dir|Encoding|Enumerable|Exception|FalseClass|File|Hash|Integer|IO|Kernel|Module|NilClass|Object|Proc|Range|Regexp|String|Struct|Symbol|Time|TrueClass)\\b",
      "scope": "type"
    },
    {
      "pattern": "(?<=\\bdef\\s)[A-Za-z_][\\w!?=]*",
      "scope": "function"
    },
    {
      "pattern": "\\b[A-Za-z_][\\w!?=]*(?=\\s*\\()",
      "scope": "function"
    },
    {
      "pattern": "[:@$][A-Za-z_][\\w]*|\\$[0-9]+",
      "scope": "variable"
    },
    {
      "pattern": "\\b(?:0[xX][0-9a-fA-F_]+|0[bB][01_]+|0[oO][0-7_]+|\\d[\\d_]*(?:\\.\\d[\\d_]*)?)\\b",
      "scope": "number"
    },
    {
      "pattern": "/(?:\\\\/|[^/\\n])+/[imxo]*",
      "scope": "regex"
    },
    {
      "pattern": "=>|\\.\\.|\\.\\.\\.|::|==|!=|<=|>=|&&|\\|\\||[+\\-*/%=&|^~!<>?:.]",
      "scope": "operator"
    }
  ]
}
