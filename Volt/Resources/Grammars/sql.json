{
  "name": "SQL",
  "extensions": [".sql"],
  "blockComments": [
    {
      "start": "^\\s*/\\*(?!.*\\*/)",
      "end": "\\*/",
      "scope": "comment"
    }
  ],
  "rules": [
    {
      "pattern": "'(?:''|[^'])*'|\"(?:\"\"|[^\"])*\"|`(?:``|[^`])*`|\\[(?:[^\\]])*\\]",
      "scope": "string"
    },
    {
      "pattern": "/\\*.*?\\*/",
      "scope": "comment"
    },
    {
      "pattern": "--.*$",
      "scope": "comment"
    },
    {
      "pattern": "\\b(?:ADD|ALTER|AND|AS|ASC|BEGIN|BETWEEN|BY|CASE|CAST|CHECK|COLUMN|COMMIT|CONSTRAINT|CREATE|CROSS|DATABASE|DEFAULT|DELETE|DESC|DISTINCT|DROP|ELSE|END|EXCEPT|EXISTS|FOREIGN|FROM|FULL|GROUP|HAVING|IF|IN|INDEX|INNER|INSERT|INTERSECT|INTO|IS|JOIN|KEY|LEFT|LIKE|LIMIT|NOT|NULL|ON|OR|ORDER|OUTER|PRIMARY|PROCEDURE|REFERENCES|RIGHT|ROLLBACK|SELECT|SET|TABLE|THEN|TOP|TRUNCATE|UNION|UNIQUE|UPDATE|VALUES|VIEW|WHEN|WHERE|WITH)\\b",
      "scope": "keyword"
    },
    {
      "pattern": "\\b(?:BIGINT|BIT|BOOLEAN|CHAR|DATE|DATETIME|DECIMAL|DOUBLE|FLOAT|INT|INTEGER|MONEY|NCHAR|NUMERIC|NVARCHAR|REAL|SMALLINT|TEXT|TIME|TIMESTAMP|TINYINT|UUID|VARCHAR|XML)\\b",
      "scope": "type"
    },
    {
      "pattern": "\\b\\w+(?=\\s*\\()",
      "scope": "function"
    },
    {
      "pattern": "@@?\\w+|:\\w+|\\?\\w*",
      "scope": "variable"
    },
    {
      "pattern": "\\b\\d+(?:\\.\\d+)?\\b",
      "scope": "number"
    },
    {
      "pattern": "<>|!=|<=|>=|\\|\\||[+\\-*/%=<>().,;]",
      "scope": "operator"
    }
  ]
}
