{
  "name": "Shell Script",
  "extensions": [".sh", ".bash", ".zsh", ".ksh"],
  "interpolation": {
    "quotes": "\"`",
    "variablePattern": "\\$(?:\\{[^}]+\\}|[A-Za-z_][\\w]*|\\d+|[#?@$!*])",
    "escapePattern": "\\\\."
  },
  "rules": [
    {
      "pattern": "\"(?:\\\\.|[^\"])*\"|'(?:\\\\.|[^'])*'|`(?:\\\\.|[^`])*`",
      "scope": "string"
    },
    {
      "pattern": "#.*$",
      "scope": "comment"
    },
    {
      "pattern": "\\b(?:alias|bg|break|case|cd|command|continue|coproc|declare|dirs|do|done|echo|elif|else|esac|eval|exec|exit|export|false|fg|fi|for|function|getopts|hash|if|in|jobs|let|local|popd|printf|pushd|pwd|read|readonly|return|select|set|shift|shopt|source|test|then|time|trap|true|type|typeset|ulimit|umask|unalias|unset|until|wait|while)\\b",
      "scope": "keyword"
    },
    {
      "pattern": "\\b[A-Za-z_][\\w]*(?=\\s*\\()",
      "scope": "function"
    },
    {
      "pattern": "\\$(?:\\{[^}]+\\}|[A-Za-z_][\\w]*|\\d+|[#?@$!*])",
      "scope": "variable"
    },
    {
      "pattern": "\\b\\d+\\b",
      "scope": "number"
    },
    {
      "pattern": "\\|\\||&&|;;|[|&;<>(){}\\[\\]=!+*/%-]",
      "scope": "operator"
    }
  ]
}
