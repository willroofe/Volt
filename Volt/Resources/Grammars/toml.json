{
  "name": "TOML",
  "extensions": [".toml"],
  "rules": [
    {
      "pattern": "\"\"\".*?\"\"\"|'''.*?'''|\"(?:\\\\.|[^\"\\\\])*\"|'[^']*'",
      "scope": "string"
    },
    {
      "pattern": "#.*$",
      "scope": "comment"
    },
    {
      "pattern": "^\\s*\\[\\[?[^\\]]+\\]\\]?",
      "scope": "keyword"
    },
    {
      "pattern": "^[A-Za-z0-9_.-]+(?=\\s*=)",
      "scope": "hashkey"
    },
    {
      "pattern": "\\b(?:true|false|inf|nan)\\b",
      "scope": "keyword"
    },
    {
      "pattern": "\\b\\d{4}-\\d{2}-\\d{2}(?:[Tt ]\\d{2}:\\d{2}:\\d{2}(?:\\.\\d+)?(?:Z|[+-]\\d{2}:\\d{2})?)?\\b",
      "scope": "number"
    },
    {
      "pattern": "\\b-?(?:0[xX][0-9a-fA-F_]+|0[oO][0-7_]+|0[bB][01_]+|\\d[\\d_]*(?:\\.\\d[\\d_]*)?(?:[eE][+-]?\\d[\\d_]*)?)\\b",
      "scope": "number"
    },
    {
      "pattern": "[=.,\\[\\]{}]",
      "scope": "operator"
    }
  ]
}
