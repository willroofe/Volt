{
  "name": "Lua",
  "extensions": [".lua"],
  "blockComments": [
    {
      "start": "^\\s*--\\[\\[(?!.*\\]\\])",
      "end": "\\]\\]",
      "scope": "comment"
    }
  ],
  "rules": [
    {
      "pattern": "\\[\\[.*?\\]\\]|\"(?:\\\\.|[^\"\\\\])*\"|'(?:\\\\.|[^'\\\\])*'",
      "scope": "string"
    },
    {
      "pattern": "--\\[\\[.*?\\]\\]|--.*$",
      "scope": "comment"
    },
    {
      "pattern": "\\b(?:and|break|do|else|elseif|end|false|for|function|goto|if|in|local|nil|not|or|repeat|return|then|true|until|while)\\b",
      "scope": "keyword"
    },
    {
      "pattern": "\\b[A-Za-z_][\\w]*(?=\\s*\\()",
      "scope": "function"
    },
    {
      "pattern": "\\b(?:self|_ENV|_G)\\b",
      "scope": "variable"
    },
    {
      "pattern": "\\b(?:0[xX][0-9a-fA-F]+|\\d+(?:\\.\\d+)?(?:[eE][+-]?\\d+)?)\\b",
      "scope": "number"
    },
    {
      "pattern": "\\.\\.|==|~=|<=|>=|[+\\-*/%^#=<>;:,.{}()\\[\\]]",
      "scope": "operator"
    }
  ]
}
