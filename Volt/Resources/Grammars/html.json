{
  "name": "HTML",
  "extensions": [".html", ".htm"],
  "blockComments": [
    {
      "start": "^\\s*<!--(?!.*-->)",
      "end": "-->",
      "scope": "comment"
    }
  ],
  "embeddedRegions": [
    {
      "start": "<style\\b[^>]*>",
      "end": "</style\\s*>",
      "extension": ".css"
    },
    {
      "start": "<script\\b[^>]*>",
      "end": "</script\\s*>",
      "extension": ".js"
    }
  ],
  "rules": [
    {
      "pattern": "<!--.*?-->",
      "scope": "comment"
    },
    {
      "pattern": "(?<=<)\\s*[A-Za-z][\\w:-]*|(?<=</)\\s*[A-Za-z][\\w:-]*",
      "scope": "keyword"
    },
    {
      "pattern": "\\b[A-Za-z_:][-\\w:.]*(?=\\s*=)",
      "scope": "hashkey"
    },
    {
      "pattern": "\"(?:&[A-Za-z0-9#]+;|\\\\.|[^\"])*\"|'(?:&[A-Za-z0-9#]+;|\\\\.|[^'])*'",
      "scope": "string"
    },
    {
      "pattern": "&(?:[A-Za-z][A-Za-z0-9]+|#[0-9]+|#x[0-9a-fA-F]+);",
      "scope": "escape"
    },
    {
      "pattern": "</?|/?>",
      "scope": "operator"
    }
  ]
}
