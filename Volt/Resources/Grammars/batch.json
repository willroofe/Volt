{
  "name": "Batch",
  "extensions": [".bat", ".cmd"],
  "rules": [
    {
      "pattern": "\"(?:[^\"]|\"\")*\"",
      "scope": "string"
    },
    {
      "pattern": "^\\s*(?:rem\\b.*|::.*)$",
      "scope": "comment"
    },
    {
      "pattern": "\\b(?:assoc|call|cd|chdir|choice|cls|color|copy|date|del|dir|echo|else|endlocal|erase|errorlevel|exit|for|ftype|goto|if|in|md|mkdir|move|not|path|pause|popd|prompt|pushd|rd|ren|rename|rmdir|set|setlocal|shift|start|time|title|type|ver|verify|vol)\\b",
      "scope": "keyword"
    },
    {
      "pattern": ":[A-Za-z_][\\w.-]*",
      "scope": "function"
    },
    {
      "pattern": "%[^%\\s]+%|%%?[A-Za-z0-9]",
      "scope": "variable"
    },
    {
      "pattern": "\\b\\d+\\b",
      "scope": "number"
    },
    {
      "pattern": "==|>=|<=|[|&<>^=+*/%-]",
      "scope": "operator"
    }
  ]
}
