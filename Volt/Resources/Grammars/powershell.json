{
  "name": "PowerShell",
  "extensions": [".ps1", ".psm1", ".psd1"],
  "blockComments": [
    {
      "start": "^\\s*<#(?!.*#>)",
      "end": "#>",
      "scope": "comment"
    }
  ],
  "interpolation": {
    "quotes": "\"",
    "variablePattern": "\\$(?:\\{[^}]+\\}|[A-Za-z_][\\w:]*|\\?|-?\\d+)",
    "escapePattern": "`."
  },
  "rules": [
    {
      "pattern": "(?:@\".*?\"@|@'.*?'@|\"(?:`.|[^\"])*\"|'(?:''|[^'])*')",
      "scope": "string"
    },
    {
      "pattern": "<#.*?#>",
      "scope": "comment"
    },
    {
      "pattern": "#.*$",
      "scope": "comment"
    },
    {
      "pattern": "\\b(?:begin|break|catch|class|continue|data|do|dynamicparam|else|elseif|end|enum|exit|filter|finally|for|foreach|from|function|if|in|param|process|return|switch|throw|trap|try|until|using|var|while|workflow)\\b",
      "scope": "keyword"
    },
    {
      "pattern": "-(?:and|as|band|bnot|bor|bxor|contains|eq|ge|gt|in|is|isnot|join|le|like|lt|match|ne|not|notcontains|notin|notlike|notmatch|or|replace|shl|shr|split|xor)\\b",
      "scope": "operator"
    },
    {
      "pattern": "\\b[A-Z][A-Za-z0-9]*(?:-[A-Z][A-Za-z0-9]*)\\b",
      "scope": "function"
    },
    {
      "pattern": "\\[[A-Za-z_][\\w.]*\\]",
      "scope": "type"
    },
    {
      "pattern": "\\$(?:\\{[^}]+\\}|[A-Za-z_][\\w:]*|\\?|-?\\d+)",
      "scope": "variable"
    },
    {
      "pattern": "\\b\\d+(?:\\.\\d+)?(?:kb|mb|gb|tb)?\\b",
      "scope": "number"
    },
    {
      "pattern": "[+\\-*/%=!<>|&?:.,;()\\[\\]{}]",
      "scope": "operator"
    }
  ]
}
