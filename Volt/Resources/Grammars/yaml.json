{
  "name": "YAML",
  "extensions": [".yml", ".yaml"],
  "rules": [
    {
      "pattern": "\"(?:\\\\.|[^\"\\\\])*\"|'(?:''|[^'])*'",
      "scope": "string"
    },
    {
      "pattern": "#.*$",
      "scope": "comment"
    },
    {
      "pattern": "^\\s*[-?]?\\s*[A-Za-z0-9_.-]+(?=\\s*:)",
      "scope": "hashkey"
    },
    {
      "pattern": "^\\s*---|^\\s*\\.\\.\\.",
      "scope": "keyword"
    },
    {
      "pattern": "\\b(?:true|false|yes|no|on|off|null|Null|NULL)\\b",
      "scope": "keyword"
    },
    {
      "pattern": "\\b-?\\d+(?:\\.\\d+)?\\b",
      "scope": "number"
    },
    {
      "pattern": "[:\\-\\[\\]{},&*|>!%@`]",
      "scope": "operator"
    }
  ]
}
