{
  "name": "Python",
  "extensions": [".py", ".pyw", ".pyi"],
  "rules": [
    {
      "pattern": "(?:[rRuUbBfF]{0,3})(?:\"\"\".*?\"\"\"|''' .*? '''|\"(?:\\\\.|[^\"\\\\])*\"|'(?:\\\\.|[^'\\\\])*')",
      "scope": "string"
    },
    {
      "pattern": "#.*$",
      "scope": "comment"
    },
    {
      "pattern": "\\b(?:and|as|assert|async|await|break|case|class|continue|def|del|elif|else|except|finally|for|from|global|if|import|in|is|lambda|match|nonlocal|not|or|pass|raise|return|try|while|with|yield)\\b",
      "scope": "keyword"
    },
    {
      "pattern": "\\b(?:False|None|True|NotImplemented|Ellipsis)\\b",
      "scope": "keyword"
    },
    {
      "pattern": "\\b(?:bool|bytes|complex|dict|float|frozenset|int|list|object|set|str|tuple|type)\\b",
      "scope": "type"
    },
    {
      "pattern": "(?<=\\bdef\\s)[A-Za-z_][\\w]*",
      "scope": "function"
    },
    {
      "pattern": "(?<=\\bclass\\s)[A-Za-z_][\\w]*",
      "scope": "type"
    },
    {
      "pattern": "\\b[A-Za-z_][\\w]*(?=\\s*\\()",
      "scope": "function"
    },
    {
      "pattern": "\\bself\\b|\\bcls\\b",
      "scope": "variable"
    },
    {
      "pattern": "\\b(?:0[xX][0-9a-fA-F_]+|0[bB][01_]+|0[oO][0-7_]+|\\d[\\d_]*(?:\\.\\d[\\d_]*)?(?:[eE][+-]?\\d[\\d_]*)?j?)\\b",
      "scope": "number"
    },
    {
      "pattern": "==|!=|<=|>=|:=|->|\\+=|-=|\\*=|/=|//=|%=|\\*\\*|[+\\-*/%=&|^~!<>:.,()\\[\\]{}]",
      "scope": "operator"
    }
  ]
}
