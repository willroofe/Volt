{
  "name": "XML",
  "extensions": [".xml", ".xaml", ".csproj", ".vbproj", ".fsproj", ".props", ".targets", ".resx", ".config"],
  "blockComments": [
    {
      "start": "^\\s*<!--(?!.*-->)",
      "end": "-->",
      "scope": "comment"
    }
  ],
  "rules": [
    {
      "pattern": "<!--.*?-->",
      "scope": "comment"
    },
    {
      "pattern": "<\\?xml.*?\\?>|<!DOCTYPE.*?>|<!\\[CDATA\\[.*?\\]\\]>",
      "scope": "keyword"
    },
    {
      "pattern": "(?<=<)\\s*[A-Za-z_][\\w.:-]*|(?<=</)\\s*[A-Za-z_][\\w.:-]*",
      "scope": "keyword"
    },
    {
      "pattern": "\\b[A-Za-z_:][-\\w:.]*(?=\\s*=)",
      "scope": "hashkey"
    },
    {
      "pattern": "\"(?:&[A-Za-z0-9#]+;|\\\\.|[^\"])*\"|'(?:&[A-Za-z0-9#]+;|\\\\.|[^'])*'",
      "scope": "string"
    },
    {
      "pattern": "&(?:[A-Za-z][A-Za-z0-9]+|#[0-9]+|#x[0-9a-fA-F]+);",
      "scope": "escape"
    },
    {
      "pattern": "</?|/?>",
      "scope": "operator"
    }
  ]
}
