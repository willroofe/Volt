{
  "name": "CSS",
  "extensions": [".css"],
  "blockComments": [
    {
      "start": "^\\s*/\\*(?!.*\\*/)",
      "end": "\\*/",
      "scope": "comment"
    }
  ],
  "rules": [
    {
      "pattern": "\"(?:\\\\.|[^\"\\\\])*\"|'(?:\\\\.|[^'\\\\])*'",
      "scope": "string"
    },
    {
      "pattern": "/\\*.*?\\*/",
      "scope": "comment"
    },
    {
      "pattern": "@[A-Za-z-]+",
      "scope": "keyword"
    },
    {
      "pattern": "--[A-Za-z0-9_-]+|\\b[A-Za-z-]+(?=\\s*:)",
      "scope": "hashkey"
    },
    {
      "pattern": "#[0-9a-fA-F]{3,8}\\b",
      "scope": "number"
    },
    {
      "pattern": "\\b-?\\d+(?:\\.\\d+)?(?:%|[a-zA-Z]+)?\\b",
      "scope": "number"
    },
    {
      "pattern": "\\b[A-Za-z-]+(?=\\s*\\()",
      "scope": "function"
    },
    {
      "pattern": "\\.[A-Za-z_][\\w-]*|#[A-Za-z_][\\w-]*",
      "scope": "type"
    },
    {
      "pattern": "[{}:;,>+~*=|^$()\\[\\]]",
      "scope": "operator"
    }
  ]
}
