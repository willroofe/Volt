<UserControl x:Class="Volt.IssuesPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:Volt"
             Focusable="True"
             Background="{DynamicResource ThemeContentBg}">
    <Grid Background="{DynamicResource ThemeContentBg}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                BorderThickness="0,0,0,1"
                Background="{DynamicResource ThemeExplorerHeaderBg}"
                BorderBrush="{DynamicResource ThemeTabBorder}">
            <Grid Height="33" Margin="10,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="SummaryText"
                           FontFamily="Segoe UI"
                           FontSize="12"
                           FontWeight="SemiBold"
                           VerticalAlignment="Center"
                           TextTrimming="CharacterEllipsis"
                           Foreground="{DynamicResource ThemeTextFg}"/>
                <TextBlock x:Name="StatusText"
                           Grid.Column="1"
                           Margin="16,0,0,0"
                           FontFamily="Segoe UI"
                           FontSize="12"
                           VerticalAlignment="Center"
                           TextTrimming="CharacterEllipsis"
                           Foreground="{DynamicResource ThemeTextFgMuted}"/>
            </Grid>
        </Border>

        <ListView x:Name="IssuesList"
                  Grid.Row="1"
                  Background="{DynamicResource ThemeContentBg}"
                  BorderThickness="0"
                  SelectionMode="Single"
                  MouseDoubleClick="OnIssuesDoubleClick"
                  ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                  ScrollViewer.VerticalScrollBarVisibility="Auto">
            <ListView.Resources>
                <Style TargetType="ListViewItem">
                    <EventSetter Event="PreviewMouseLeftButtonDown" Handler="OnIssueItemPreviewMouseLeftButtonDown"/>
                    <EventSetter Event="RequestBringIntoView" Handler="OnIssueItemRequestBringIntoView"/>
                    <Setter Property="Padding" Value="0"/>
                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="BorderThickness" Value="0"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="ListViewItem">
                                <Border x:Name="Bd"
                                        Background="{TemplateBinding Background}"
                                        Padding="0">
                                    <ContentPresenter/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Bd" Property="Background" Value="{DynamicResource ThemeExplorerItemHover}"/>
                                    </Trigger>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter TargetName="Bd" Property="Background" Value="{DynamicResource ThemeExplorerItemSelected}"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </ListView.Resources>
            <ListView.ItemTemplate>
                <DataTemplate DataType="{x:Type local:IssueRow}">
                    <Grid MinHeight="28" Margin="8,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="28"/>
                            <ColumnDefinition Width="140"/>
                            <ColumnDefinition Width="110"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="{Binding SeverityGlyph}"
                                   FontFamily="{x:Static local:Codicons.Font}"
                                   FontSize="13"
                                   VerticalAlignment="Center"
                                   HorizontalAlignment="Center"
                                   Foreground="{Binding SeverityBrush}"/>
                        <TextBlock Grid.Column="1"
                                   Text="{Binding FileName}"
                                   FontFamily="Segoe UI"
                                   FontSize="12"
                                   VerticalAlignment="Center"
                                   TextTrimming="CharacterEllipsis"
                                   Foreground="{DynamicResource ThemeTextFg}"/>
                        <TextBlock Grid.Column="2"
                                   Text="{Binding Location}"
                                   Margin="8,0,0,0"
                                   FontFamily="Segoe UI"
                                   FontSize="12"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource ThemeTextFgMuted}"/>
                        <TextBlock Grid.Column="3"
                                   Text="{Binding Message}"
                                   Margin="8,0,0,0"
                                   FontFamily="Segoe UI"
                                   FontSize="12"
                                   VerticalAlignment="Center"
                                   TextTrimming="CharacterEllipsis"
                                   Foreground="{DynamicResource ThemeTextFg}"/>
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </Grid>
</UserControl>
