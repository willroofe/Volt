<UserControl x:Class="Volt.CommandPalette"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Visibility="Collapsed">
    <UserControl.Resources>
        <Style TargetType="ListBoxItem">
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                CornerRadius="4">
                            <ContentPresenter/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <!-- Compact scrollbar without arrow buttons for the palette list -->
        <ControlTemplate x:Key="PaletteScrollBar" TargetType="ScrollBar">
            <Grid>
                <Border Background="Transparent"/>
                <Track x:Name="PART_Track" IsDirectionReversed="True">
                    <Track.DecreaseRepeatButton>
                        <RepeatButton Style="{StaticResource ScrollBarTrackButton}"
                                      Command="ScrollBar.PageUpCommand"/>
                    </Track.DecreaseRepeatButton>
                    <Track.Thumb>
                        <Thumb Style="{StaticResource ScrollBarThumb}" Margin="2"/>
                    </Track.Thumb>
                    <Track.IncreaseRepeatButton>
                        <RepeatButton Style="{StaticResource ScrollBarTrackButton}"
                                      Command="ScrollBar.PageDownCommand"/>
                    </Track.IncreaseRepeatButton>
                </Track>
            </Grid>
        </ControlTemplate>
    </UserControl.Resources>
    <Grid>
        <!-- Overlay (semi-transparent dark background) -->
        <Border x:Name="_overlay"
                Background="{DynamicResource ThemeOverlayBg}"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Stretch"
                MouseLeftButtonDown="OnOverlayClick"/>

        <!-- Panel -->
        <Border x:Name="_panel"
                Width="420"
                CornerRadius="6"
                BorderThickness="1"
                HorizontalAlignment="Center"
                VerticalAlignment="Top"
                Margin="0,50,0,0"
                Background="{DynamicResource ThemeMenuPopupBg}"
                BorderBrush="{DynamicResource ThemeMenuPopupBorder}">
            <Border.Effect>
                <DropShadowEffect BlurRadius="16" Opacity="0.3" ShadowDepth="2"/>
            </Border.Effect>
            <StackPanel>
                <!-- Input area -->
                <Border Background="{DynamicResource ThemeContentBg}" CornerRadius="6,6,0,0">
                    <DockPanel Margin="10,8,10,8">
                        <TextBlock x:Name="_filterPrefix"
                                   DockPanel.Dock="Left"
                                   VerticalAlignment="Center"
                                   FontFamily="Segoe UI"
                                   FontSize="14"
                                   Foreground="{DynamicResource ThemeTextFgMuted}"/>
                        <TextBox x:Name="_filterInput"
                                 BorderThickness="0"
                                 FontFamily="Segoe UI"
                                 FontSize="14"
                                 Padding="0"
                                 VerticalContentAlignment="Center"
                                 Background="Transparent"
                                 Foreground="{DynamicResource ThemeTextFg}"
                                 CaretBrush="{DynamicResource ThemeTextFg}"
                                 TextChanged="OnInputTextChanged"/>
                    </DockPanel>
                </Border>

                <!-- Separator -->
                <Border Height="1" Background="{DynamicResource ThemeMenuPopupBorder}"/>

                <!-- List -->
                <ListBox x:Name="_commandList"
                         BorderThickness="0"
                         FocusVisualStyle="{x:Null}"
                         Focusable="False"
                         Background="Transparent"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <ListBox.Template>
                        <ControlTemplate TargetType="ListBox">
                            <ScrollViewer Focusable="False"
                                          MaxHeight="320"
                                          CanContentScroll="False">
                                <ScrollViewer.Resources>
                                    <Style TargetType="ScrollBar">
                                        <Setter Property="OverridesDefaultStyle" Value="True"/>
                                        <Setter Property="Width" Value="10"/>
                                        <Setter Property="Template" Value="{StaticResource PaletteScrollBar}"/>
                                    </Style>
                                </ScrollViewer.Resources>
                                <ItemsPresenter/>
                            </ScrollViewer>
                        </ControlTemplate>
                    </ListBox.Template>
                </ListBox>

                <!-- No results message -->
                <TextBlock x:Name="_noResults"
                           Text="No matching commands"
                           FontFamily="Segoe UI"
                           FontSize="13"
                           Margin="12,8,12,8"
                           Visibility="Collapsed"
                           Foreground="{DynamicResource ThemeTextFgMuted}"/>

                <!-- Placeholder -->
                <TextBlock x:Name="_placeholder"
                           Text="Type to search..."
                           FontFamily="Segoe UI"
                           FontSize="13"
                           FontStyle="Italic"
                           Margin="12,8,12,8"
                           Visibility="Collapsed"
                           Foreground="{DynamicResource ThemeTextFgMuted}"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
