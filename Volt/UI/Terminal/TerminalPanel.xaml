<UserControl x:Class="Volt.TerminalPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:Volt"
             Background="{DynamicResource ThemeContentBg}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <!-- Match dock panel headers (TabRegion): explorer header + tab strip -->
        <Border Grid.Row="0"
                BorderThickness="0,0,0,1"
                Background="{DynamicResource ThemeExplorerHeaderBg}"
                BorderBrush="{DynamicResource ThemeTabBorder}">
            <DockPanel Height="33">
                <Button x:Name="ShellPickerButton" DockPanel.Dock="Right"
                        Width="22" Height="28" Margin="0,0,2,0"
                        Content="&#xEAB4;"
                        FontFamily="{x:Static local:Codicons.Font}" FontSize="8"
                        Foreground="{DynamicResource ThemeButtonFg}"
                        Background="Transparent" BorderThickness="0"
                        Focusable="False" Cursor="Hand"
                        ToolTip="New terminal (choose shell)"
                        Click="OnShellPickerClicked">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bd" Background="Transparent" CornerRadius="3">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bd" Property="Background"
                                            Value="{DynamicResource ThemeButtonHover}"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
                <Button x:Name="AddButton" DockPanel.Dock="Right"
                        Width="28" Height="28" Margin="2,0,0,0"
                        Content="&#xEA60;"
                        FontFamily="{x:Static local:Codicons.Font}" FontSize="10"
                        Foreground="{DynamicResource ThemeButtonFg}"
                        Background="Transparent" BorderThickness="0"
                        Focusable="False" Cursor="Hand"
                        ToolTip="New terminal"
                        Click="OnAddClicked">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bd" Background="Transparent" CornerRadius="3">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bd" Property="Background"
                                            Value="{DynamicResource ThemeButtonHover}"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
                <ScrollViewer HorizontalScrollBarVisibility="Hidden"
                              VerticalScrollBarVisibility="Disabled"
                              CanContentScroll="False"
                              Focusable="False">
                    <StackPanel x:Name="TabStrip" Orientation="Horizontal"/>
                </ScrollViewer>
            </DockPanel>
        </Border>
        <Grid Grid.Row="1">
            <ContentPresenter x:Name="ActiveContent"/>

            <Border x:Name="FindPanel"
                    Visibility="Collapsed"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Top"
                    Margin="0,8,22,0"
                    Panel.ZIndex="5"
                    CornerRadius="6"
                    BorderThickness="1"
                    Background="{DynamicResource ThemeTabBarBg}"
                    BorderBrush="{DynamicResource ThemeBorderBrush}">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="20" Opacity="0.6" ShadowDepth="4" Direction="270"/>
                </Border.Effect>
                <Grid Margin="10,8,10,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0"
                            MinWidth="220"
                            BorderThickness="1"
                            CornerRadius="3"
                            SnapsToDevicePixels="True"
                            BorderBrush="{DynamicResource ThemeMenuPopupBorder}">
                        <DockPanel>
                            <TextBlock x:Name="FindMatchCountText"
                                       DockPanel.Dock="Right"
                                       Width="50"
                                       FontFamily="Segoe UI"
                                       FontSize="11"
                                       VerticalAlignment="Center"
                                       TextAlignment="Right"
                                       Margin="2,0,6,0"
                                       Foreground="{DynamicResource ThemeTextFgMuted}"/>
                            <TextBox x:Name="FindInput"
                                     MinWidth="220"
                                     BorderThickness="0"
                                     FontFamily="Segoe UI"
                                     FontSize="13"
                                     Padding="4,3,0,3"
                                     VerticalContentAlignment="Center"
                                     Background="Transparent"
                                     Foreground="{DynamicResource ThemeTextFg}"
                                     CaretBrush="{DynamicResource ThemeTextFg}"
                                     SelectionBrush="{DynamicResource ThemeInputSelection}"
                                     TextChanged="OnFindInputTextChanged"
                                     PreviewKeyDown="OnFindInputPreviewKeyDown"/>
                        </DockPanel>
                    </Border>

                    <Button x:Name="FindPrevButton"
                            Grid.Column="1"
                            Style="{StaticResource FindBarNavButton}"
                            ToolTip="Previous (Shift+Enter)"
                            Click="OnFindPrevClicked">
                        <TextBlock Text="&#xEAB7;" FontFamily="{x:Static local:Codicons.Font}" FontSize="12"/>
                    </Button>
                    <Button x:Name="FindNextButton"
                            Grid.Column="2"
                            Style="{StaticResource FindBarNavButton}"
                            ToolTip="Next (Enter)"
                            Click="OnFindNextClicked">
                        <TextBlock Text="&#xEAB4;" FontFamily="{x:Static local:Codicons.Font}" FontSize="12"/>
                    </Button>
                    <Button x:Name="FindCloseButton"
                            Grid.Column="3"
                            Style="{StaticResource FindBarNavButton}"
                            ToolTip="Close (Escape)"
                            Click="OnFindCloseClicked">
                        <TextBlock Text="&#xEA76;" FontFamily="{x:Static local:Codicons.Font}" FontSize="12"/>
                    </Button>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
