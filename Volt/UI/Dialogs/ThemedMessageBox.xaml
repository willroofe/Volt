<Window x:Class="Volt.ThemedMessageBox"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Volt"
        Width="520" MinHeight="170" MaxHeight="520"
        SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False">
    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="32" ResizeBorderThickness="0"
                      GlassFrameThickness="-1"
                      UseAeroCaptionButtons="False"/>
    </WindowChrome.WindowChrome>
    <DockPanel Background="{DynamicResource ThemeContentBg}">
        <!-- Title bar -->
        <Grid DockPanel.Dock="Top" Background="{DynamicResource ThemeChromeBrush}" Height="32">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock x:Name="TitleText" Grid.Column="0" Text="Volt"
                       VerticalAlignment="Center" Margin="12,0,0,0"
                       FontFamily="Segoe UI" FontSize="12"
                       Foreground="{DynamicResource ThemeTextFg}"
                       IsHitTestVisible="False"/>
            <Button Grid.Column="1" Style="{StaticResource CloseButton}"
                    Click="OnClose"/>
        </Grid>

        <Border DockPanel.Dock="Top" Height="1" Background="{DynamicResource ThemeBorderBrush}"/>

        <!-- Content -->
        <Grid Margin="24,20,24,20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <ScrollViewer Grid.Row="0"
                          MaxHeight="340"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <TextBlock x:Name="MessageText"
                           FontFamily="Segoe UI" FontSize="13"
                           Foreground="{DynamicResource ThemeTextFg}"
                           TextWrapping="Wrap"
                           VerticalAlignment="Top"/>
            </ScrollViewer>

            <StackPanel x:Name="ButtonPanel" Grid.Row="1"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Margin="0,16,0,0"/>
        </Grid>
    </DockPanel>
</Window>
