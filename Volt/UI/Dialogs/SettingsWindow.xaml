<Window x:Class="Volt.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:Volt"
        Title="Settings" Height="420" Width="550"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        BorderBrush="{DynamicResource ThemeChromeBrush}"
        BorderThickness="0,0,1,1">
    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="32" ResizeBorderThickness="0"
                      GlassFrameThickness="-1"
                      UseAeroCaptionButtons="False"/>
    </WindowChrome.WindowChrome>
    <Window.Resources>
        <Style x:Key="NavHeader" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{DynamicResource ThemeTextFgMuted}"/>
            <Setter Property="Margin" Value="16,10,0,2"/>
        </Style>
        <Style x:Key="NavButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding" Value="24,5,16,5"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="{DynamicResource ThemeButtonFg}"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource ThemeNavHover}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="NavButtonActive" TargetType="Button" BasedOn="{StaticResource NavButton}">
            <Setter Property="Background" Value="{DynamicResource ThemeNavActive}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
        <Style x:Key="SettingLabel" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="{DynamicResource ThemeTextFg}"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style x:Key="SectionHeader" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{DynamicResource ThemeTextFgStrong}"/>
            <Setter Property="Margin" Value="0,0,0,16"/>
        </Style>

        <!-- Themed ComboBox -->
        <Style x:Key="ThemedComboBoxToggle" TargetType="ToggleButton">
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="IsTabStop" Value="False"/>
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="ClickMode" Value="Press"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="Bd" Background="Transparent"
                                BorderBrush="{DynamicResource ThemeMenuPopupBorder}" BorderThickness="1"
                                CornerRadius="3" SnapsToDevicePixels="True">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="24"/>
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="1">
                                    <TextBlock Text="&#xEAB4;" FontFamily="{x:Static local:Codicons.Font}" FontSize="9"
                                               Foreground="{DynamicResource ThemeTextFg}"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource ThemeButtonHover}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="Foreground" Value="{DynamicResource ThemeTextFg}"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton Style="{StaticResource ThemedComboBoxToggle}"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"/>
                            <ContentPresenter IsHitTestVisible="False"
                                              Content="{TemplateBinding SelectionBoxItem}"
                                              ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                              Margin="8,0,28,0"
                                              VerticalAlignment="Center"
                                              HorizontalAlignment="Left"/>
                            <Popup IsOpen="{TemplateBinding IsDropDownOpen}"
                                   Placement="Bottom" Focusable="False"
                                   AllowsTransparency="True" PopupAnimation="None">
                                <Border Background="{DynamicResource ThemeMenuPopupBg}"
                                        BorderBrush="{DynamicResource ThemeMenuPopupBorder}"
                                        BorderThickness="1" CornerRadius="3"
                                        MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}"
                                        Margin="0,1,4,4">
                                    <Border.Effect>
                                        <DropShadowEffect ShadowDepth="1" Opacity="0.2" BlurRadius="4"/>
                                    </Border.Effect>
                                    <ScrollViewer MaxHeight="200" VerticalScrollBarVisibility="Auto"
                                                  CanContentScroll="False">
                                        <StackPanel IsItemsHost="True" Margin="0,2"
                                                    KeyboardNavigation.DirectionalNavigation="Contained"/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="ComboBoxItem">
            <Setter Property="Foreground" Value="{DynamicResource ThemeTextFg}"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="Bd" Background="Transparent" Padding="10,5"
                                CornerRadius="4" Margin="4,1">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource ThemeMenuItemHover}"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource ThemeNavActive}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Themed Slider -->
        <Style x:Key="SliderThumb" TargetType="Thumb">
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Thumb">
                        <Ellipse x:Name="Dot" Width="14" Height="14"
                                 Fill="{DynamicResource ThemeTextFg}"
                                 Stroke="{DynamicResource ThemeMenuPopupBorder}" StrokeThickness="1"/>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Dot" Property="Fill" Value="{DynamicResource ThemeTextFgStrong}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="Slider">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Slider">
                        <Grid>
                            <Border Height="3" VerticalAlignment="Center" CornerRadius="1.5"
                                    Background="{DynamicResource ThemeMenuPopupBorder}"/>
                            <Track x:Name="PART_Track">
                                <Track.Thumb>
                                    <Thumb Style="{StaticResource SliderThumb}"/>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Themed action buttons (OK/Cancel) -->
        <Style x:Key="ActionButton" TargetType="Button">
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="{DynamicResource ThemeTextFg}"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="Transparent"
                                BorderBrush="{DynamicResource ThemeMenuPopupBorder}"
                                BorderThickness="1"
                                CornerRadius="3" Padding="12,4"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource ThemeButtonHover}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource ThemeMenuItemHover}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    <DockPanel>
        <!-- Custom title bar -->
        <Grid DockPanel.Dock="Top" Background="{DynamicResource ThemeChromeBrush}" Height="32">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0" Text="Settings"
                       VerticalAlignment="Center" Margin="12,0,0,0"
                       FontFamily="Segoe UI" FontSize="12"
                       Foreground="{DynamicResource ThemeTextFg}"
                       IsHitTestVisible="False"/>

            <Button Grid.Column="1" Style="{StaticResource CloseButton}"
                    Click="OnCancel"/>
        </Grid>

        <Border DockPanel.Dock="Top" Height="1" Background="{DynamicResource ThemeBorderBrush}"/>

        <!-- Main content area -->
        <Grid Background="{DynamicResource ThemeContentBg}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="160"/>
                <ColumnDefinition Width="1"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Left nav -->
            <Border Grid.Column="0" Background="{DynamicResource ThemeNavBg}">
                <StackPanel Margin="0,4,0,0">
                    <TextBlock Text="APPLICATION" Style="{StaticResource NavHeader}"/>
                    <Button x:Name="NavTheme" Content="Theme"
                            Style="{StaticResource NavButtonActive}"
                            Click="OnNavTheme"/>
                    <Button x:Name="NavCommandPalette" Content="Command Palette"
                            Style="{StaticResource NavButton}"
                            Click="OnNavCommandPalette"/>
                    <Button x:Name="NavKeybinds" Content="Keybinds"
                            Style="{StaticResource NavButton}"
                            Click="OnNavKeybinds"/>

                    <TextBlock Text="EDITOR" Style="{StaticResource NavHeader}" Margin="16,12,0,2"/>
                    <Button x:Name="NavFont" Content="Font"
                            Style="{StaticResource NavButton}"
                            Click="OnNavFont"/>
                    <Button x:Name="NavCaret" Content="Caret"
                            Style="{StaticResource NavButton}"
                            Click="OnNavCaret"/>
                    <Button x:Name="NavTabs" Content="Tabs"
                            Style="{StaticResource NavButton}"
                            Click="OnNavTabs"/>
                    <Button x:Name="NavFind" Content="Find"
                            Style="{StaticResource NavButton}"
                            Click="OnNavFind"/>
                    <Button x:Name="NavIndentation" Content="Indentation"
                            Style="{StaticResource NavButton}"
                            Click="OnNavIndentation"/>
                    <Button x:Name="NavWordWrap" Content="Word Wrap"
                            Style="{StaticResource NavButton}"
                            Click="OnNavWordWrap"/>

                    <TextBlock Text="PANELS" Style="{StaticResource NavHeader}" Margin="16,12,0,2"/>
                    <Button x:Name="NavExplorer" Content="Explorer"
                            Style="{StaticResource NavButton}"
                            Click="OnNavExplorer"/>
                    <Button x:Name="NavTerminal" Content="Terminal"
                            Style="{StaticResource NavButton}"
                            Click="OnNavTerminal"/>
                </StackPanel>
            </Border>

            <!-- Separator -->
            <Border Grid.Column="1" Background="{DynamicResource ThemeBorderBrush}"/>

            <!-- Right content area -->
            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="1"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Theme section -->
                <ScrollViewer x:Name="ThemeScroller" Grid.Row="0"
                              Template="{StaticResource ThemedScrollViewer}"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <StackPanel Margin="24,20">
                        <TextBlock Text="Theme" Style="{StaticResource SectionHeader}"/>

                        <TextBlock Text="Colour theme" Style="{StaticResource SettingLabel}" Margin="0,0,0,4"/>
                        <ComboBox x:Name="ColorThemeBox" Width="200" Height="26"
                                  HorizontalAlignment="Left" Margin="0,0,0,16"
                                  VerticalContentAlignment="Center" FontSize="13"/>

                    </StackPanel>
                </ScrollViewer>

                <!-- Command Palette section -->
                <ScrollViewer x:Name="CommandPaletteScroller" Grid.Row="0"
                              Template="{StaticResource ThemedScrollViewer}"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled"
                              Visibility="Collapsed">
                    <StackPanel Margin="24,20">
                        <TextBlock Text="Command Palette" Style="{StaticResource SectionHeader}"/>

                        <TextBlock Text="Position" Style="{StaticResource SettingLabel}" Margin="0,0,0,4"/>
                        <ComboBox x:Name="CmdPalettePosBox" Width="100" Height="26"
                                  HorizontalAlignment="Left" Margin="0,0,0,16"
                                  VerticalContentAlignment="Center" FontSize="13">
                            <ComboBoxItem Content="Top"/>
                            <ComboBoxItem Content="Center"/>
                        </ComboBox>
                    </StackPanel>
                </ScrollViewer>

                <!-- Keybinds section -->
                <ScrollViewer x:Name="KeybindsScroller" Grid.Row="0"
                              Template="{StaticResource ThemedScrollViewer}"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled"
                              Visibility="Collapsed">
                    <StackPanel Margin="24,20">
                        <DockPanel Margin="0,0,0,16">
                            <TextBlock Text="Keybinds" Style="{StaticResource SectionHeader}"
                                       DockPanel.Dock="Left" Margin="0"/>
                            <Button x:Name="ResetAllKeybinds" Content="Reset All"
                                    Style="{StaticResource ActionButton}"
                                    HorizontalAlignment="Right" VerticalAlignment="Top"
                                    Click="OnResetAllKeybinds"/>
                        </DockPanel>
                        <ItemsControl x:Name="KeybindList"/>
                    </StackPanel>
                </ScrollViewer>

                <!-- Font section -->
                <ScrollViewer x:Name="FontScroller" Grid.Row="0"
                              Template="{StaticResource ThemedScrollViewer}"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled"
                              Visibility="Collapsed">
                    <StackPanel Margin="24,20">
                        <TextBlock Text="Font" Style="{StaticResource SectionHeader}"/>

                        <TextBlock Text="Font family" Style="{StaticResource SettingLabel}" Margin="0,0,0,4"/>
                        <ComboBox x:Name="FontFamilyBox" Width="200" Height="26"
                                  HorizontalAlignment="Left" Margin="0,0,0,16"
                                  VerticalContentAlignment="Center" FontSize="13"/>

                        <TextBlock Text="Font size" Style="{StaticResource SettingLabel}" Margin="0,0,0,4"/>
                        <ComboBox x:Name="FontSizeBox" Width="80" Height="26"
                                  HorizontalAlignment="Left" Margin="0,0,0,16"
                                  VerticalContentAlignment="Center" FontSize="13"/>

                        <TextBlock Text="Font weight" Style="{StaticResource SettingLabel}" Margin="0,0,0,4"/>
                        <ComboBox x:Name="FontWeightBox" Width="140" Height="26"
                                  HorizontalAlignment="Left" Margin="0,0,0,16"
                                  VerticalContentAlignment="Center" FontSize="13"/>

                        <TextBlock Text="Line height" Style="{StaticResource SettingLabel}" Margin="0,0,0,4"/>
                        <ComboBox x:Name="LineHeightBox" Width="80" Height="26"
                                  HorizontalAlignment="Left" Margin="0,0,0,16"
                                  VerticalContentAlignment="Center" FontSize="13"/>
                    </StackPanel>
                </ScrollViewer>

                <!-- Caret section -->
                <ScrollViewer x:Name="CaretScroller" Grid.Row="0"
                              Template="{StaticResource ThemedScrollViewer}"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled"
                              Visibility="Collapsed">
                    <StackPanel Margin="24,20">
                        <TextBlock Text="Caret" Style="{StaticResource SectionHeader}"/>

                        <TextBlock Text="Caret style" Style="{StaticResource SettingLabel}" Margin="0,0,0,4"/>
                        <ComboBox x:Name="CaretStyleBox" Width="100" Height="26"
                                  HorizontalAlignment="Left" Margin="0,0,0,16"
                                  VerticalContentAlignment="Center" FontSize="13">
                            <ComboBoxItem Content="Bar"/>
                            <ComboBoxItem Content="Block"/>
                        </ComboBox>

                        <TextBlock Text="Caret blink" Style="{StaticResource SettingLabel}" Margin="0,0,0,4"/>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                            <Slider x:Name="CaretBlinkSlider" Width="180" Minimum="0" Maximum="1000"
                                    TickFrequency="50" IsSnapToTickEnabled="True"
                                    VerticalAlignment="Center"
                                    ValueChanged="OnCaretBlinkSliderChanged"/>
                            <TextBlock x:Name="CaretBlinkLabel" Style="{StaticResource SettingLabel}"
                                       Margin="10,0,0,0" Width="50"/>
                        </StackPanel>

                    </StackPanel>
                </ScrollViewer>

                <!-- Indentation section -->
                <ScrollViewer x:Name="IndentationScroller" Grid.Row="0"
                              Template="{StaticResource ThemedScrollViewer}"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled"
                              Visibility="Collapsed">
                    <StackPanel Margin="24,20">
                        <TextBlock Text="Indentation" Style="{StaticResource SectionHeader}"/>

                        <TextBlock Text="Tab size" Style="{StaticResource SettingLabel}" Margin="0,0,0,4"/>
                        <ComboBox x:Name="TabSizeBox" Width="70" Height="26"
                                  HorizontalAlignment="Left" Margin="0,0,0,16"
                                  VerticalContentAlignment="Center" FontSize="13">
                            <ComboBoxItem Content="2"/>
                            <ComboBoxItem Content="4"/>
                            <ComboBoxItem Content="8"/>
                        </ComboBox>

                        <TextBlock Text="Indent guides" Style="{StaticResource SettingLabel}" Margin="0,0,0,4"/>
                        <ComboBox x:Name="IndentGuidesBox" Width="100" Height="26"
                                  HorizontalAlignment="Left" Margin="0,0,0,16"
                                  VerticalContentAlignment="Center" FontSize="13">
                            <ComboBoxItem Content="On"/>
                            <ComboBoxItem Content="Off"/>
                        </ComboBox>
                    </StackPanel>
                </ScrollViewer>

                <!-- Tabs section -->
                <ScrollViewer x:Name="TabsScroller" Grid.Row="0"
                              Template="{StaticResource ThemedScrollViewer}"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled"
                              Visibility="Collapsed">
                    <StackPanel Margin="24,20">
                        <TextBlock Text="Tabs" Style="{StaticResource SectionHeader}"/>

                        <TextBlock Text="Fixed width tabs" Style="{StaticResource SettingLabel}" Margin="0,0,0,4"/>
                        <ComboBox x:Name="FixedWidthTabsBox" Width="100" Height="26"
                                  HorizontalAlignment="Left" Margin="0,0,0,16"
                                  VerticalContentAlignment="Center" FontSize="13">
                            <ComboBoxItem Content="On"/>
                            <ComboBoxItem Content="Off"/>
                        </ComboBox>
                    </StackPanel>
                </ScrollViewer>

                <!-- Find section -->
                <ScrollViewer x:Name="FindScroller" Grid.Row="0"
                              Template="{StaticResource ThemedScrollViewer}"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled"
                              Visibility="Collapsed">
                    <StackPanel Margin="24,20">
                        <TextBlock Text="Find" Style="{StaticResource SectionHeader}"/>

                        <TextBlock Text="Find bar position" Style="{StaticResource SettingLabel}" Margin="0,0,0,4"/>
                        <ComboBox x:Name="FindBarPosBox" Width="100" Height="26"
                                  HorizontalAlignment="Left" Margin="0,0,0,16"
                                  VerticalContentAlignment="Center" FontSize="13">
                            <ComboBoxItem Content="Top"/>
                            <ComboBoxItem Content="Bottom"/>
                        </ComboBox>

                        <TextBlock Text="Add selection to find" Style="{StaticResource SettingLabel}" Margin="0,0,0,4"/>
                        <ComboBox x:Name="FindSeedSelBox" Width="100" Height="26"
                                  HorizontalAlignment="Left" Margin="0,0,0,16"
                                  VerticalContentAlignment="Center" FontSize="13">
                            <ComboBoxItem Content="On"/>
                            <ComboBoxItem Content="Off"/>
                        </ComboBox>
                    </StackPanel>
                </ScrollViewer>

                <!-- Word Wrap section -->
                <ScrollViewer x:Name="WordWrapScroller" Grid.Row="0"
                              Template="{StaticResource ThemedScrollViewer}"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled"
                              Visibility="Collapsed">
                    <StackPanel Margin="24,20">
                        <TextBlock Text="Word Wrap" Style="{StaticResource SectionHeader}"/>

                        <TextBlock Text="Word wrap" Style="{StaticResource SettingLabel}" Margin="0,0,0,4"/>
                        <ComboBox x:Name="WordWrapBox" Width="100" Height="26"
                                  HorizontalAlignment="Left" Margin="0,0,0,16"
                                  VerticalContentAlignment="Center" FontSize="13">
                            <ComboBoxItem Content="On"/>
                            <ComboBoxItem Content="Off"/>
                        </ComboBox>

                        <TextBlock Text="Break at word boundaries" Style="{StaticResource SettingLabel}" Margin="0,0,0,4"/>
                        <ComboBox x:Name="WordWrapAtWordsBox" Width="100" Height="26"
                                  HorizontalAlignment="Left" Margin="0,0,0,16"
                                  VerticalContentAlignment="Center" FontSize="13">
                            <ComboBoxItem Content="On"/>
                            <ComboBoxItem Content="Off"/>
                        </ComboBox>

                        <TextBlock Text="Indent wrapped lines" Style="{StaticResource SettingLabel}" Margin="0,0,0,4"/>
                        <ComboBox x:Name="WordWrapIndentBox" Width="100" Height="26"
                                  HorizontalAlignment="Left" Margin="0,0,0,16"
                                  VerticalContentAlignment="Center" FontSize="13">
                            <ComboBoxItem Content="On"/>
                            <ComboBoxItem Content="Off"/>
                        </ComboBox>
                    </StackPanel>
                </ScrollViewer>

                <!-- Explorer section -->
                <ScrollViewer x:Name="ExplorerScroller" Grid.Row="0"
                              Template="{StaticResource ThemedScrollViewer}"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled"
                              Visibility="Collapsed">
                    <StackPanel Margin="24,20">
                        <TextBlock Text="Explorer" Style="{StaticResource SectionHeader}"/>
                    </StackPanel>
                </ScrollViewer>

                <!-- Terminal section -->
                <ScrollViewer x:Name="TerminalScroller" Grid.Row="0"
                              Template="{StaticResource ThemedScrollViewer}"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled"
                              Visibility="Collapsed">
                    <StackPanel Margin="24,20">
                        <TextBlock Text="Terminal" Style="{StaticResource SectionHeader}"/>

                        <TextBlock Text="Shell" Style="{StaticResource SettingLabel}" Margin="0,0,0,4"/>
                        <ComboBox x:Name="TerminalShellBox" Width="200" Height="26"
                                  HorizontalAlignment="Left" Margin="0,0,0,12"
                                  VerticalContentAlignment="Center" FontSize="13">
                            <ComboBoxItem Content="PowerShell"/>
                            <ComboBoxItem Content="Command Prompt"/>
                        </ComboBox>

                        <TextBlock Text="Shell arguments" Style="{StaticResource SettingLabel}" Margin="0,0,0,4"/>
                        <TextBox x:Name="TerminalShellArgsBox" Style="{StaticResource RoundedTextBox}"
                                 Height="26" Padding="8,4" Margin="0,0,0,12"
                                 VerticalContentAlignment="Center" FontSize="13"
                                 Foreground="{DynamicResource ThemeTextFg}"/>

                        <TextBlock Text="Scrollback lines" Style="{StaticResource SettingLabel}" Margin="0,0,0,4"/>
                        <TextBox x:Name="TerminalScrollbackBox" Style="{StaticResource RoundedTextBox}"
                                 Width="120" Height="26" HorizontalAlignment="Left" Padding="8,4"
                                 VerticalContentAlignment="Center" FontSize="13"
                                 Foreground="{DynamicResource ThemeTextFg}"/>
                    </StackPanel>
                </ScrollViewer>

                <!-- Bottom bar -->
                <Border Grid.Row="1" Background="{DynamicResource ThemeBorderBrush}"/>
                <StackPanel Grid.Row="2" Orientation="Horizontal"
                            HorizontalAlignment="Right" Margin="16,12">
                    <Button Content="Apply" Width="75" Height="28" Margin="0,0,8,0"
                            Style="{StaticResource ActionButton}"
                            Click="OnApply"/>
                    <Button Content="OK" Width="75" Height="28" Margin="0,0,8,0"
                            Style="{StaticResource ActionButton}"
                            Click="OnOK" IsDefault="True"/>
                    <Button Content="Cancel" Width="75" Height="28"
                            Style="{StaticResource ActionButton}"
                            Click="OnCancel" IsCancel="True"/>
                </StackPanel>
            </Grid>
        </Grid>
    </DockPanel>
</Window>
