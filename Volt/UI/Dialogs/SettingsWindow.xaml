<Window x:Class="Volt.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:Volt"
        Title="Settings" Height="640" Width="760"
        MinHeight="520" MinWidth="680"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        BorderBrush="{DynamicResource ThemeChromeBrush}"
        BorderThickness="0,0,1,1">
    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="32" ResizeBorderThickness="6"
                      GlassFrameThickness="-1"
                      UseAeroCaptionButtons="False"/>
    </WindowChrome.WindowChrome>
    <Window.Resources>
        <Style x:Key="NavHeader" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{DynamicResource ThemeTextFgMuted}"/>
            <Setter Property="Margin" Value="18,12,0,3"/>
        </Style>
        <Style x:Key="NavButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding" Value="14,5,16,5"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="{DynamicResource ThemeButtonFg}"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Tag" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="2"/>
                                    <ColumnDefinition Width="12"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Border x:Name="Accent" Grid.Column="0"
                                        Background="{DynamicResource ThemeTextFg}"
                                        Visibility="Collapsed"/>
                                <ContentPresenter Grid.Column="2" VerticalAlignment="Center"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource ThemeNavHover}"/>
                            </Trigger>
                            <Trigger Property="Tag" Value="Active">
                                <Setter TargetName="Accent" Property="Visibility" Value="Visible"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="NavButtonActive" TargetType="Button" BasedOn="{StaticResource NavButton}">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Tag" Value="Active"/>
        </Style>
        <Style x:Key="SettingLabel" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="{DynamicResource ThemeTextFg}"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style x:Key="SectionHeader" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{DynamicResource ThemeTextFgStrong}"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
        </Style>
        <Style x:Key="SectionPanel" TargetType="StackPanel">
            <Setter Property="Margin" Value="0,0,0,16"/>
        </Style>
        <Style x:Key="SectionDivider" TargetType="Border">
            <Setter Property="Height" Value="1"/>
            <Setter Property="Margin" Value="0,0,0,18"/>
            <Setter Property="Background" Value="{DynamicResource ThemeBorderBrush}"/>
        </Style>
        <Style x:Key="SettingRow" TargetType="Grid">
            <Setter Property="Margin" Value="0,0,0,6"/>
            <Setter Property="MinHeight" Value="34"/>
        </Style>
        <Style x:Key="KeybindResetButton" TargetType="Button">
            <Setter Property="Width" Value="28"/>
            <Setter Property="Height" Value="26"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource ThemeTextFgMuted}"/>
            <Setter Property="FontFamily" Value="{x:Static local:Codicons.Font}"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="ToolTip" Value="Reset to default"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                BorderBrush="{DynamicResource ThemeMenuPopupBorder}"
                                BorderThickness="1,0,0,0"
                                CornerRadius="0,3,3,0">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource ThemeButtonHover}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource ThemeMenuItemHover}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Themed ComboBox -->
        <Style x:Key="ThemedComboBoxToggle" TargetType="ToggleButton">
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="IsTabStop" Value="False"/>
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="ClickMode" Value="Press"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="Bd" Background="Transparent"
                                BorderBrush="{DynamicResource ThemeMenuPopupBorder}" BorderThickness="1"
                                CornerRadius="3" SnapsToDevicePixels="True">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="24"/>
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="1">
                                    <TextBlock Text="&#xEAB4;" FontFamily="{x:Static local:Codicons.Font}" FontSize="9"
                                               Foreground="{DynamicResource ThemeTextFg}"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource ThemeButtonHover}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="Foreground" Value="{DynamicResource ThemeTextFg}"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton Style="{StaticResource ThemedComboBoxToggle}"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"/>
                            <ContentPresenter IsHitTestVisible="False"
                                              Content="{TemplateBinding SelectionBoxItem}"
                                              ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                              Margin="8,0,28,0"
                                              VerticalAlignment="Center"
                                              HorizontalAlignment="Left"/>
                            <Popup IsOpen="{TemplateBinding IsDropDownOpen}"
                                   Placement="Bottom" Focusable="False"
                                   AllowsTransparency="True" PopupAnimation="None">
                                <Border Background="{DynamicResource ThemeMenuPopupBg}"
                                        BorderBrush="{DynamicResource ThemeMenuPopupBorder}"
                                        BorderThickness="1" CornerRadius="3"
                                        MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}"
                                        Margin="0,1,4,4">
                                    <Border.Effect>
                                        <DropShadowEffect ShadowDepth="1" Opacity="0.2" BlurRadius="4"/>
                                    </Border.Effect>
                                    <ScrollViewer MaxHeight="200" VerticalScrollBarVisibility="Auto"
                                                  CanContentScroll="False">
                                        <StackPanel IsItemsHost="True" Margin="0,2"
                                                    KeyboardNavigation.DirectionalNavigation="Contained"/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="ComboBoxItem">
            <Setter Property="Foreground" Value="{DynamicResource ThemeTextFg}"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="Bd" Background="Transparent" Padding="10,5"
                                CornerRadius="4" Margin="4,1">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource ThemeMenuItemHover}"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource ThemeNavActive}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Themed Slider -->
        <Style x:Key="SliderThumb" TargetType="Thumb">
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Thumb">
                        <Ellipse x:Name="Dot" Width="14" Height="14"
                                 Fill="{DynamicResource ThemeTextFg}"
                                 Stroke="{DynamicResource ThemeMenuPopupBorder}" StrokeThickness="1"/>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Dot" Property="Fill" Value="{DynamicResource ThemeTextFgStrong}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="Slider">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Slider">
                        <Grid>
                            <Border Height="3" VerticalAlignment="Center" CornerRadius="1.5"
                                    Background="{DynamicResource ThemeMenuPopupBorder}"/>
                            <Track x:Name="PART_Track">
                                <Track.Thumb>
                                    <Thumb Style="{StaticResource SliderThumb}"/>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Themed action buttons (OK/Cancel) -->
        <Style x:Key="ActionButton" TargetType="Button">
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="{DynamicResource ThemeTextFg}"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="Transparent"
                                BorderBrush="{DynamicResource ThemeMenuPopupBorder}"
                                BorderThickness="1"
                                CornerRadius="3" Padding="12,4"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource ThemeButtonHover}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource ThemeMenuItemHover}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    <DockPanel>
        <!-- Custom title bar -->
        <Grid DockPanel.Dock="Top" Background="{DynamicResource ThemeChromeBrush}" Height="32">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0" Text="Settings"
                       VerticalAlignment="Center" Margin="12,0,0,0"
                       FontFamily="Segoe UI" FontSize="12"
                       Foreground="{DynamicResource ThemeTextFg}"
                       IsHitTestVisible="False"/>

            <Button Grid.Column="1" Style="{StaticResource CloseButton}"
                    Click="OnCancel"/>
        </Grid>

        <Border DockPanel.Dock="Top" Height="1" Background="{DynamicResource ThemeBorderBrush}"/>

        <!-- Main content area -->
        <Grid Background="{DynamicResource ThemeContentBg}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="180"/>
                <ColumnDefinition Width="1"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Left nav -->
            <Border Grid.Column="0" Background="{DynamicResource ThemeNavBg}">
                <ScrollViewer Template="{StaticResource ThemedScrollViewer}"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <StackPanel x:Name="NavList" Margin="0,4,0,12">
                        <TextBlock x:Name="NavApplicationHeader" Text="APPLICATION" Style="{StaticResource NavHeader}"/>
                        <Button x:Name="NavTheme" Content="Theme"
                                Style="{StaticResource NavButtonActive}"
                                Click="OnNavTheme"/>
                        <Button x:Name="NavCommandPalette" Content="Command Palette"
                                Style="{StaticResource NavButton}"
                                Click="OnNavCommandPalette"/>
                        <Button x:Name="NavKeybinds" Content="Keybinds"
                                Style="{StaticResource NavButton}"
                                Click="OnNavKeybinds"/>

                        <TextBlock x:Name="NavEditorHeader" Text="EDITOR" Style="{StaticResource NavHeader}" Margin="16,12,0,2"/>
                        <Button x:Name="NavFont" Content="Font"
                                Style="{StaticResource NavButton}"
                                Click="OnNavFont"/>
                        <Button x:Name="NavCaret" Content="Caret"
                                Style="{StaticResource NavButton}"
                                Click="OnNavCaret"/>
                        <Button x:Name="NavTabs" Content="Tabs"
                                Style="{StaticResource NavButton}"
                                Click="OnNavTabs"/>
                        <Button x:Name="NavFind" Content="Find"
                                Style="{StaticResource NavButton}"
                                Click="OnNavFind"/>
                        <Button x:Name="NavIndentation" Content="Indentation"
                                Style="{StaticResource NavButton}"
                                Click="OnNavIndentation"/>
                        <Button x:Name="NavWordWrap" Content="Word Wrap"
                                Style="{StaticResource NavButton}"
                                Click="OnNavWordWrap"/>

                        <TextBlock x:Name="NavPanelsHeader" Text="PANELS" Style="{StaticResource NavHeader}" Margin="16,12,0,2"/>
                        <Button x:Name="NavExplorer" Content="Explorer"
                                Style="{StaticResource NavButton}"
                                Click="OnNavExplorer"/>
                        <Button x:Name="NavTerminal" Content="Terminal"
                                Style="{StaticResource NavButton}"
                                Click="OnNavTerminal"/>
                    </StackPanel>
                </ScrollViewer>
            </Border>

            <!-- Separator -->
            <Border Grid.Column="1" Background="{DynamicResource ThemeBorderBrush}"/>

            <!-- Right content area -->
            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="1"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="1"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Search -->
                <Border x:Name="SettingsSearchBorder" Grid.Row="0"
                        Margin="24,8,24,8"
                        Height="30"
                        Background="{DynamicResource ThemeContentBg}"
                        BorderThickness="1" CornerRadius="3"
                        SnapsToDevicePixels="True"
                        BorderBrush="{DynamicResource ThemeMenuPopupBorder}">
                    <DockPanel>
                        <Button x:Name="ClearSettingsSearchBtn"
                                DockPanel.Dock="Right"
                                Style="{StaticResource MatchCaseButton}"
                                Width="24" Height="22"
                                Margin="0,2,2,2" Padding="0"
                                BorderThickness="0"
                                Cursor="Hand"
                                Focusable="False"
                                Visibility="Hidden"
                                ToolTip="Clear search"
                                Background="Transparent"
                                Foreground="{DynamicResource ThemeTextFgMuted}"
                                Click="OnClearSettingsSearchClick">
                            <TextBlock Text="&#xEA76;" FontFamily="{x:Static local:Codicons.Font}" FontSize="13"/>
                        </Button>
                        <TextBlock DockPanel.Dock="Left"
                                   Text="&#xEA6D;" FontFamily="{x:Static local:Codicons.Font}" FontSize="13"
                                   Foreground="{DynamicResource ThemeTextFgMuted}"
                                   VerticalAlignment="Center" Margin="7,0,0,0"/>
                        <TextBox x:Name="SettingsSearchInput"
                                 BorderThickness="0"
                                 FontFamily="Segoe UI" FontSize="13"
                                 Padding="5,2,0,2"
                                 VerticalContentAlignment="Center"
                                 Background="Transparent"
                                 Foreground="{DynamicResource ThemeTextFg}"
                                 CaretBrush="{DynamicResource ThemeTextFg}"
                                 SelectionBrush="{DynamicResource ThemeInputSelection}"
                                 ToolTip="Search settings"
                                 TextChanged="OnSettingsSearchTextChanged"
                                 GotKeyboardFocus="OnSettingsSearchFocusChanged"
                                 LostKeyboardFocus="OnSettingsSearchFocusChanged"/>
                    </DockPanel>
                </Border>

                <Border Grid.Row="1" Background="{DynamicResource ThemeBorderBrush}"/>

                <ScrollViewer x:Name="SettingsScroller" Grid.Row="2"
                              Template="{StaticResource ThemedScrollViewer}"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled"
                              ScrollChanged="OnSettingsScrollChanged">
                    <StackPanel x:Name="SettingsContent"
                                Margin="36,18,36,18"
                                MaxWidth="860"
                                HorizontalAlignment="Stretch">
                        <!-- Theme section -->
                        <StackPanel x:Name="ThemeSection" Style="{StaticResource SectionPanel}">
                            <TextBlock Text="Theme" Style="{StaticResource SectionHeader}"/>

                            <Grid x:Name="ThemeColorThemeRow" Style="{StaticResource SettingRow}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Colour theme" Style="{StaticResource SettingLabel}"/>
                                <ComboBox x:Name="ColorThemeBox" Width="220" Height="26"
                                          Grid.Column="1"
                                          HorizontalAlignment="Right"
                                          VerticalContentAlignment="Center" FontSize="13"/>
                            </Grid>
                        </StackPanel>

                        <!-- Command Palette section -->
                        <StackPanel x:Name="CommandPaletteSection" Style="{StaticResource SectionPanel}">
                            <Border Style="{StaticResource SectionDivider}"/>
                            <TextBlock Text="Command Palette" Style="{StaticResource SectionHeader}"/>

                            <Grid x:Name="CommandPalettePositionRow" Style="{StaticResource SettingRow}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Position" Style="{StaticResource SettingLabel}"/>
                                <ComboBox x:Name="CmdPalettePosBox" Width="100" Height="26"
                                          Grid.Column="1"
                                          HorizontalAlignment="Right"
                                          VerticalContentAlignment="Center" FontSize="13">
                                    <ComboBoxItem Content="Top"/>
                                    <ComboBoxItem Content="Center"/>
                                </ComboBox>
                            </Grid>
                        </StackPanel>

                        <!-- Keybinds section -->
                        <StackPanel x:Name="KeybindsSection" Style="{StaticResource SectionPanel}">
                            <Border Style="{StaticResource SectionDivider}"/>
                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Keybinds" Style="{StaticResource SectionHeader}" Margin="0"/>
                                <Button x:Name="ResetAllKeybinds" Content="Reset All"
                                        Style="{StaticResource ActionButton}"
                                        Grid.Column="1"
                                        HorizontalAlignment="Right" VerticalAlignment="Top"
                                        Click="OnResetAllKeybinds"/>
                            </Grid>
                            <ItemsControl x:Name="KeybindList"/>
                        </StackPanel>

                        <!-- Font section -->
                        <StackPanel x:Name="FontSection" Style="{StaticResource SectionPanel}">
                            <Border Style="{StaticResource SectionDivider}"/>
                            <TextBlock Text="Font" Style="{StaticResource SectionHeader}"/>

                            <Grid x:Name="FontFamilyRow" Style="{StaticResource SettingRow}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Font family" Style="{StaticResource SettingLabel}"/>
                                <ComboBox x:Name="FontFamilyBox" Width="220" Height="26"
                                          Grid.Column="1"
                                          HorizontalAlignment="Right"
                                          VerticalContentAlignment="Center" FontSize="13"/>
                            </Grid>

                            <Grid x:Name="FontSizeRow" Style="{StaticResource SettingRow}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Font size" Style="{StaticResource SettingLabel}"/>
                                <ComboBox x:Name="FontSizeBox" Width="80" Height="26"
                                          Grid.Column="1"
                                          HorizontalAlignment="Right"
                                          VerticalContentAlignment="Center" FontSize="13"/>
                            </Grid>

                            <Grid x:Name="FontWeightRow" Style="{StaticResource SettingRow}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Font weight" Style="{StaticResource SettingLabel}"/>
                                <ComboBox x:Name="FontWeightBox" Width="140" Height="26"
                                          Grid.Column="1"
                                          HorizontalAlignment="Right"
                                          VerticalContentAlignment="Center" FontSize="13"/>
                            </Grid>

                            <Grid x:Name="LineHeightRow" Style="{StaticResource SettingRow}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Line height" Style="{StaticResource SettingLabel}"/>
                                <ComboBox x:Name="LineHeightBox" Width="80" Height="26"
                                          Grid.Column="1"
                                          HorizontalAlignment="Right"
                                          VerticalContentAlignment="Center" FontSize="13"/>
                            </Grid>
                        </StackPanel>

                        <!-- Caret section -->
                        <StackPanel x:Name="CaretSection" Style="{StaticResource SectionPanel}">
                            <Border Style="{StaticResource SectionDivider}"/>
                            <TextBlock Text="Caret" Style="{StaticResource SectionHeader}"/>

                            <Grid x:Name="CaretStyleRow" Style="{StaticResource SettingRow}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Caret style" Style="{StaticResource SettingLabel}"/>
                                <ComboBox x:Name="CaretStyleBox" Width="100" Height="26"
                                          Grid.Column="1"
                                          HorizontalAlignment="Right"
                                          VerticalContentAlignment="Center" FontSize="13">
                                    <ComboBoxItem Content="Bar"/>
                                    <ComboBoxItem Content="Block"/>
                                </ComboBox>
                            </Grid>

                            <Grid x:Name="CaretBlinkRow" Style="{StaticResource SettingRow}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Caret blink" Style="{StaticResource SettingLabel}"/>
                                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right">
                                    <Slider x:Name="CaretBlinkSlider" Width="180" Minimum="0" Maximum="1000"
                                            TickFrequency="50" IsSnapToTickEnabled="True"
                                            VerticalAlignment="Center"
                                            ValueChanged="OnCaretBlinkSliderChanged"/>
                                    <TextBlock x:Name="CaretBlinkLabel" Style="{StaticResource SettingLabel}"
                                               Margin="10,0,0,0" Width="50"/>
                                </StackPanel>
                            </Grid>
                        </StackPanel>

                        <!-- Tabs section -->
                        <StackPanel x:Name="TabsSection" Style="{StaticResource SectionPanel}">
                            <Border Style="{StaticResource SectionDivider}"/>
                            <TextBlock Text="Tabs" Style="{StaticResource SectionHeader}"/>

                            <Grid x:Name="TabsFixedWidthRow" Style="{StaticResource SettingRow}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Fixed width tabs" Style="{StaticResource SettingLabel}"/>
                                <ComboBox x:Name="FixedWidthTabsBox" Width="100" Height="26"
                                          Grid.Column="1"
                                          HorizontalAlignment="Right"
                                          VerticalContentAlignment="Center" FontSize="13">
                                    <ComboBoxItem Content="On"/>
                                    <ComboBoxItem Content="Off"/>
                                </ComboBox>
                            </Grid>
                        </StackPanel>

                        <!-- Find section -->
                        <StackPanel x:Name="FindSection" Style="{StaticResource SectionPanel}">
                            <Border Style="{StaticResource SectionDivider}"/>
                            <TextBlock Text="Find" Style="{StaticResource SectionHeader}"/>

                            <Grid x:Name="FindBarPositionRow" Style="{StaticResource SettingRow}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Find bar position" Style="{StaticResource SettingLabel}"/>
                                <ComboBox x:Name="FindBarPosBox" Width="100" Height="26"
                                          Grid.Column="1"
                                          HorizontalAlignment="Right"
                                          VerticalContentAlignment="Center" FontSize="13">
                                    <ComboBoxItem Content="Top"/>
                                    <ComboBoxItem Content="Bottom"/>
                                </ComboBox>
                            </Grid>

                            <Grid x:Name="FindSeedSelectionRow" Style="{StaticResource SettingRow}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Add selection to find" Style="{StaticResource SettingLabel}"/>
                                <ComboBox x:Name="FindSeedSelBox" Width="100" Height="26"
                                          Grid.Column="1"
                                          HorizontalAlignment="Right"
                                          VerticalContentAlignment="Center" FontSize="13">
                                    <ComboBoxItem Content="On"/>
                                    <ComboBoxItem Content="Off"/>
                                </ComboBox>
                            </Grid>
                        </StackPanel>

                        <!-- Indentation section -->
                        <StackPanel x:Name="IndentationSection" Style="{StaticResource SectionPanel}">
                            <Border Style="{StaticResource SectionDivider}"/>
                            <TextBlock Text="Indentation" Style="{StaticResource SectionHeader}"/>

                            <Grid x:Name="IndentationTabSizeRow" Style="{StaticResource SettingRow}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Tab size" Style="{StaticResource SettingLabel}"/>
                                <ComboBox x:Name="TabSizeBox" Width="70" Height="26"
                                          Grid.Column="1"
                                          HorizontalAlignment="Right"
                                          VerticalContentAlignment="Center" FontSize="13">
                                    <ComboBoxItem Content="2"/>
                                    <ComboBoxItem Content="4"/>
                                    <ComboBoxItem Content="8"/>
                                </ComboBox>
                            </Grid>

                            <Grid x:Name="IndentationGuidesRow" Style="{StaticResource SettingRow}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Indent guides" Style="{StaticResource SettingLabel}"/>
                                <ComboBox x:Name="IndentGuidesBox" Width="100" Height="26"
                                          Grid.Column="1"
                                          HorizontalAlignment="Right"
                                          VerticalContentAlignment="Center" FontSize="13">
                                    <ComboBoxItem Content="On"/>
                                    <ComboBoxItem Content="Off"/>
                                </ComboBox>
                            </Grid>
                        </StackPanel>

                        <!-- Word Wrap section -->
                        <StackPanel x:Name="WordWrapSection" Style="{StaticResource SectionPanel}">
                            <Border Style="{StaticResource SectionDivider}"/>
                            <TextBlock Text="Word Wrap" Style="{StaticResource SectionHeader}"/>

                            <Grid x:Name="WordWrapEnabledRow" Style="{StaticResource SettingRow}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Word wrap" Style="{StaticResource SettingLabel}"/>
                                <ComboBox x:Name="WordWrapBox" Width="100" Height="26"
                                          Grid.Column="1"
                                          HorizontalAlignment="Right"
                                          VerticalContentAlignment="Center" FontSize="13">
                                    <ComboBoxItem Content="On"/>
                                    <ComboBoxItem Content="Off"/>
                                </ComboBox>
                            </Grid>

                            <Grid x:Name="WordWrapAtWordsRow" Style="{StaticResource SettingRow}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Break at word boundaries" Style="{StaticResource SettingLabel}"/>
                                <ComboBox x:Name="WordWrapAtWordsBox" Width="100" Height="26"
                                          Grid.Column="1"
                                          HorizontalAlignment="Right"
                                          VerticalContentAlignment="Center" FontSize="13">
                                    <ComboBoxItem Content="On"/>
                                    <ComboBoxItem Content="Off"/>
                                </ComboBox>
                            </Grid>

                            <Grid x:Name="WordWrapIndentRow" Style="{StaticResource SettingRow}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Indent wrapped lines" Style="{StaticResource SettingLabel}"/>
                                <ComboBox x:Name="WordWrapIndentBox" Width="100" Height="26"
                                          Grid.Column="1"
                                          HorizontalAlignment="Right"
                                          VerticalContentAlignment="Center" FontSize="13">
                                    <ComboBoxItem Content="On"/>
                                    <ComboBoxItem Content="Off"/>
                                </ComboBox>
                            </Grid>
                        </StackPanel>

                        <!-- Explorer section -->
                        <StackPanel x:Name="ExplorerSection" Style="{StaticResource SectionPanel}">
                            <Border Style="{StaticResource SectionDivider}"/>
                            <TextBlock Text="Explorer" Style="{StaticResource SectionHeader}"/>

                            <Grid x:Name="ExplorerFileIconsRow" Style="{StaticResource SettingRow}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="File icons" Style="{StaticResource SettingLabel}"/>
                                <ComboBox x:Name="ExplorerFileIconsBox" Width="100" Height="26"
                                          Grid.Column="1"
                                          HorizontalAlignment="Right"
                                          VerticalContentAlignment="Center" FontSize="13"/>
                            </Grid>

                            <Grid x:Name="ExplorerRevealActiveFileRow" Style="{StaticResource SettingRow}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Reveal active file" Style="{StaticResource SettingLabel}"/>
                                <ComboBox x:Name="ExplorerRevealActiveFileBox" Width="100" Height="26"
                                          Grid.Column="1"
                                          HorizontalAlignment="Right"
                                          VerticalContentAlignment="Center" FontSize="13">
                                    <ComboBoxItem Content="On"/>
                                    <ComboBoxItem Content="Off"/>
                                </ComboBox>
                            </Grid>
                        </StackPanel>

                        <!-- Terminal section -->
                        <StackPanel x:Name="TerminalSection" Style="{StaticResource SectionPanel}">
                            <Border Style="{StaticResource SectionDivider}"/>
                            <TextBlock Text="Terminal" Style="{StaticResource SectionHeader}"/>

                            <Grid x:Name="TerminalShellRow" Style="{StaticResource SettingRow}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Shell" Style="{StaticResource SettingLabel}"/>
                                <ComboBox x:Name="TerminalShellBox" Width="220" Height="26"
                                          Grid.Column="1"
                                          HorizontalAlignment="Right"
                                          VerticalContentAlignment="Center" FontSize="13"/>
                            </Grid>

                            <Grid x:Name="TerminalShellArgsRow" Style="{StaticResource SettingRow}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Shell arguments" Style="{StaticResource SettingLabel}"/>
                                <TextBox x:Name="TerminalShellArgsBox" Style="{StaticResource RoundedTextBox}"
                                         Grid.Column="1"
                                         Width="260" Height="26" Padding="8,4"
                                         HorizontalAlignment="Right"
                                         VerticalContentAlignment="Center" FontSize="13"
                                         Foreground="{DynamicResource ThemeTextFg}"/>
                            </Grid>

                            <Grid x:Name="TerminalScrollbackRow" Style="{StaticResource SettingRow}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Scrollback lines" Style="{StaticResource SettingLabel}"/>
                                <TextBox x:Name="TerminalScrollbackBox" Style="{StaticResource RoundedTextBox}"
                                         Grid.Column="1"
                                         Width="120" Height="26" HorizontalAlignment="Right" Padding="8,4"
                                         VerticalContentAlignment="Center" FontSize="13"
                                         Foreground="{DynamicResource ThemeTextFg}"/>
                            </Grid>
                        </StackPanel>

                        <StackPanel x:Name="NoSettingsResults" Visibility="Collapsed"
                                    Margin="0,72,0,0" HorizontalAlignment="Center">
                            <TextBlock Text="No settings match your search."
                                       FontFamily="Segoe UI" FontSize="13"
                                       Foreground="{DynamicResource ThemeTextFgMuted}"/>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>

                <!-- Bottom bar -->
                <Border Grid.Row="3" Background="{DynamicResource ThemeBorderBrush}"/>
                <StackPanel Grid.Row="4" Orientation="Horizontal"
                            HorizontalAlignment="Right" Margin="16,12">
                    <Button x:Name="ApplyButton" Content="Apply" Width="75" Height="28" Margin="0,0,8,0"
                            Style="{StaticResource ActionButton}"
                            Click="OnApply"/>
                    <Button Content="OK" Width="75" Height="28" Margin="0,0,8,0"
                            Style="{StaticResource ActionButton}"
                            Click="OnOK" IsDefault="True"/>
                    <Button Content="Cancel" Width="75" Height="28"
                            Style="{StaticResource ActionButton}"
                            Click="OnCancel" IsCancel="True"/>
                </StackPanel>
            </Grid>
        </Grid>
    </DockPanel>
</Window>
