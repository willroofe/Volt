<Window x:Class="Volt.UpdateAvailableDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Update Available"
        Width="560" Height="420"
        MinWidth="460" MinHeight="320"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        ShowInTaskbar="False">
    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="32" ResizeBorderThickness="6"
                      GlassFrameThickness="-1"
                      UseAeroCaptionButtons="False"/>
    </WindowChrome.WindowChrome>
    <DockPanel Background="{DynamicResource ThemeContentBg}">
        <!-- Title bar -->
        <Grid DockPanel.Dock="Top" Background="{DynamicResource ThemeChromeBrush}" Height="32">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="Update Available"
                       VerticalAlignment="Center" Margin="12,0,0,0"
                       FontFamily="Segoe UI" FontSize="12"
                       Foreground="{DynamicResource ThemeTextFg}"
                       IsHitTestVisible="False"/>
            <Button Grid.Column="1" Style="{StaticResource CloseButton}"
                    Click="OnClose"/>
        </Grid>

        <Border DockPanel.Dock="Top" Height="1" Background="{DynamicResource ThemeBorderBrush}"/>

        <!-- Content -->
        <Grid Margin="24,20,24,20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0">
                <TextBlock x:Name="VersionText"
                           FontFamily="Segoe UI" FontSize="15" FontWeight="SemiBold"
                           Foreground="{DynamicResource ThemeTextFg}"
                           TextWrapping="Wrap"/>
                <TextBlock Text="Review the release notes before installing."
                           Margin="0,6,0,0"
                           FontFamily="Segoe UI" FontSize="12"
                           Foreground="{DynamicResource ThemeTextFgMuted}"/>
            </StackPanel>

            <Border Grid.Row="1"
                    Margin="0,16,0,0"
                    BorderBrush="{DynamicResource ThemeBorderBrush}"
                    BorderThickness="1"
                    Background="{DynamicResource ThemeContentBg}">
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled"
                              Padding="12">
                    <TextBlock x:Name="ReleaseNotesText"
                               FontFamily="Segoe UI" FontSize="12"
                               Foreground="{DynamicResource ThemeTextFg}"
                               TextWrapping="Wrap"/>
                </ScrollViewer>
            </Border>

            <StackPanel Grid.Row="2"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Margin="0,16,0,0">
                <Button Content="Open Release Page"
                        Style="{StaticResource DialogButton}"
                        Margin="0,0,8,0"
                        Click="OnOpenReleasePage"/>
                <Button Content="Not Now"
                        Style="{StaticResource DialogButton}"
                        Margin="0,0,8,0"
                        IsCancel="True"
                        Click="OnNotNow"/>
                <Button Content="Install and Restart"
                        Style="{StaticResource DialogButton}"
                        IsDefault="True"
                        Click="OnInstall"/>
            </StackPanel>
        </Grid>
    </DockPanel>
</Window>
