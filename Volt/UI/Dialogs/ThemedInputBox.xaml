<Window x:Class="Volt.ThemedInputBox"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Input"
        Width="380" Height="190"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False">
    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="32" ResizeBorderThickness="0"
                      GlassFrameThickness="-1"
                      UseAeroCaptionButtons="False"/>
    </WindowChrome.WindowChrome>
    <DockPanel Background="{DynamicResource ThemeContentBg}">
        <!-- Title bar -->
        <Grid DockPanel.Dock="Top" Background="{DynamicResource ThemeChromeBrush}" Height="32">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock x:Name="TitleText" Grid.Column="0" Text="Input"
                       VerticalAlignment="Center" Margin="12,0,0,0"
                       FontFamily="Segoe UI" FontSize="12"
                       Foreground="{DynamicResource ThemeTextFg}"
                       IsHitTestVisible="False"/>
            <Button Grid.Column="1" Style="{StaticResource CloseButton}"
                    Click="OnClose"/>
        </Grid>

        <!-- Separator -->
        <Border DockPanel.Dock="Top" Height="1" Background="{DynamicResource ThemeBorderBrush}"/>

        <!-- Content area -->
        <Grid Margin="24,20,24,20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock x:Name="PromptText" Grid.Row="0"
                       FontFamily="Segoe UI" FontSize="13"
                       Foreground="{DynamicResource ThemeTextFg}"
                       TextWrapping="Wrap"
                       Margin="0,0,0,8"/>

            <TextBox x:Name="InputTextBox" Grid.Row="1"
                     FontFamily="Segoe UI" FontSize="13"
                     Padding="4,3,4,3"
                     Foreground="{DynamicResource ThemeTextFg}"
                     CaretBrush="{DynamicResource ThemeTextFg}"
                     SelectionBrush="{DynamicResource ThemeInputSelection}">
                <TextBox.Template>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="Bd" Background="{DynamicResource ThemeContentBg}"
                                BorderBrush="{DynamicResource ThemeMenuPopupBorder}"
                                BorderThickness="1" CornerRadius="3">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource ThemeTextFgMuted}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </TextBox.Template>
            </TextBox>

            <StackPanel Grid.Row="2"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Margin="0,16,0,0">
                <Button Content="OK" Style="{StaticResource DialogButton}"
                        IsDefault="True" Click="OnOk"/>
                <Button Content="Cancel" Style="{StaticResource DialogButton}"
                        IsCancel="True" Click="OnCancel"/>
            </StackPanel>
        </Grid>
    </DockPanel>
</Window>
