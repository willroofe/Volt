<Window x:Class="Volt.AboutWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="About Volt"
        Width="360" SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False">
    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="32" ResizeBorderThickness="0"
                      GlassFrameThickness="-1"
                      UseAeroCaptionButtons="False"/>
    </WindowChrome.WindowChrome>
    <DockPanel Background="{DynamicResource ThemeContentBg}">
        <!-- Title bar -->
        <Grid DockPanel.Dock="Top" Background="{DynamicResource ThemeChromeBrush}" Height="32">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="About Volt"
                       VerticalAlignment="Center" Margin="12,0,0,0"
                       FontFamily="Segoe UI" FontSize="12"
                       Foreground="{DynamicResource ThemeTextFg}"
                       IsHitTestVisible="False"/>
            <Button Grid.Column="1" Style="{StaticResource CloseButton}"
                    Click="OnClose"/>
        </Grid>

        <Border DockPanel.Dock="Top" Height="1" Background="{DynamicResource ThemeBorderBrush}"/>

        <!-- Content -->
        <Grid Margin="24,20,24,20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Same paths and colouring as the Volt menu header (MainWindow.xaml). -->
                <Viewbox Grid.Row="0" Width="48" Height="48" HorizontalAlignment="Center">
                    <!-- Padded canvas: miter at triangle apex extends above original Y=50 origin. -->
                    <Canvas Width="400" Height="390">
                        <Path Stroke="{DynamicResource ThemeTextFg}" StrokeThickness="16"
                              StrokeLineJoin="Miter" StrokeMiterLimit="10"
                              StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                              Fill="Transparent"
                              Data="M200,80.192 L350,340 L50,340 Z"/>
                        <Path Stroke="{DynamicResource ThemeTextFg}" StrokeThickness="16"
                              StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                              StrokeLineJoin="Round"
                              Fill="Transparent"
                              Data="M150,166.795 L300,253.397 M100,253.397 L150,340 M150,340 L225,210.096"/>
                    </Canvas>
                </Viewbox>

                <TextBlock Grid.Row="1" Text="Volt" HorizontalAlignment="Center" Margin="0,8,0,0"
                           FontFamily="Segoe UI" FontSize="20" FontWeight="SemiBold"
                           Foreground="{DynamicResource ThemeTextFg}"/>

                <TextBlock Grid.Row="2" x:Name="VersionText" HorizontalAlignment="Center" Margin="0,4,0,0"
                           FontFamily="Segoe UI" FontSize="12"
                           Foreground="{DynamicResource ThemeTextFgMuted}"/>

                <TextBlock Grid.Row="3" x:Name="CopyrightText" HorizontalAlignment="Center" Margin="0,4,0,0"
                           FontFamily="Segoe UI" FontSize="11"
                           Foreground="{DynamicResource ThemeTextFgMuted}"/>

                <TextBlock Grid.Row="4" Margin="8,10,8,0"
                           TextWrapping="Wrap" TextAlignment="Center"
                           FontFamily="Segoe UI" FontSize="10"
                           Foreground="{DynamicResource ThemeTextFgMuted}"
                           Text="UI glyphs use Microsoft vscode Codicons (CC BY 4.0). See Codicons-LICENSE.txt next to the app."/>
            </Grid>

            <!-- Update status + progress -->
            <StackPanel Grid.Row="1">
                <TextBlock x:Name="UpdateStatusText" HorizontalAlignment="Center"
                           FontFamily="Segoe UI" FontSize="12"
                           Foreground="{DynamicResource ThemeTextFgMuted}"
                           Visibility="Hidden"/>

                <ProgressBar x:Name="UpdateProgress" Height="4" Margin="0,6,0,0"
                             Minimum="0" Maximum="100"
                             Foreground="{DynamicResource ThemeTextFg}"
                             Background="{DynamicResource ThemeBorderBrush}"
                             BorderThickness="0"
                             Visibility="Hidden"/>

                <!-- Buttons -->
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Right" Margin="0,12,0,0">
                    <Button x:Name="UpdateButton" Content="Check for Updates"
                            Style="{StaticResource DialogButton}"
                            Margin="0,0,8,0"
                            Click="OnCheckForUpdates"/>
                    <Button Content="Close"
                            Style="{StaticResource DialogButton}"
                            IsCancel="True"
                            Click="OnClose"/>
                </StackPanel>
            </StackPanel>
        </Grid>
    </DockPanel>
</Window>
