<Window x:Class="Volt.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:Volt"
        Title="Volt" Height="600" Width="900"
        Icon="/Resources/Volt.ico"
        Background="{DynamicResource ThemeChromeBrush}"
        BorderBrush="{DynamicResource ThemeChromeBrush}"
        BorderThickness="0,0,1,1"
        WindowStartupLocation="CenterScreen">
    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="32" ResizeBorderThickness="6"
                      GlassFrameThickness="-1"
                      UseAeroCaptionButtons="False"/>
    </WindowChrome.WindowChrome>
    <Window.Resources>
        <Style x:Key="TopLevelMenuItem" TargetType="MenuItem">
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="MenuItem">
                        <Grid>
                            <Border x:Name="Bd" Background="Transparent" Padding="10,0"
                                    CornerRadius="4" Margin="2,4">
                                <ContentPresenter ContentSource="Header"
                                                  VerticalAlignment="Center"
                                                  RecognizesAccessKey="True"/>
                            </Border>
                            <Popup x:Name="PART_Popup"
                                   IsOpen="{Binding IsSubmenuOpen, RelativeSource={RelativeSource TemplatedParent}}"
                                   Placement="Bottom"
                                   HorizontalOffset="1"
                                   VerticalOffset="-4"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   PopupAnimation="None">
                                <Border Background="{DynamicResource ThemeMenuPopupBg}"
                                        BorderBrush="{DynamicResource ThemeMenuPopupBorder}" BorderThickness="1"
                                        CornerRadius="3" Margin="0,0,6,6">
                                    <Border.Effect>
                                        <DropShadowEffect ShadowDepth="2" Opacity="0.4" BlurRadius="8"/>
                                    </Border.Effect>
                                    <StackPanel IsItemsHost="True" Margin="0,3"
                                                KeyboardNavigation.DirectionalNavigation="Cycle"/>
                                </Border>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource ThemeButtonHover}"/>
                            </Trigger>
                            <Trigger Property="IsSubmenuOpen" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource ThemeButtonHover}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="EditorHorizSplitterStyle" TargetType="GridSplitter">
            <Setter Property="Panel.ZIndex" Value="1"/>
            <Setter Property="Background" Value="{DynamicResource ThemeBorderBrush}"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="UseLayoutRounding" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="GridSplitter">
                        <Border Background="{TemplateBinding Background}"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="EditorVertSplitterStyle" TargetType="GridSplitter">
            <Setter Property="Panel.ZIndex" Value="1"/>
            <Setter Property="Background" Value="{DynamicResource ThemeBorderBrush}"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="UseLayoutRounding" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="GridSplitter">
                        <Border Background="{TemplateBinding Background}"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="MenuItemBaseStyle" TargetType="MenuItem" BasedOn="{StaticResource {x:Type MenuItem}}">
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="{DynamicResource ThemeTextFg}"/>
        </Style>
        <Style x:Key="MenuItemDropdownStyle" TargetType="MenuItem" BasedOn="{StaticResource MenuItemBaseStyle}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="MenuItem">
                        <Border x:Name="Bd" Background="Transparent"
                                CornerRadius="4" Margin="4,1">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="28" SharedSizeGroup="Icon"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto" SharedSizeGroup="Shortcut"/>
                                </Grid.ColumnDefinitions>
                                <ContentPresenter Grid.Column="0" ContentSource="Icon"
                                                  HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"
                                                  Width="16" Height="16"/>
                                <ContentPresenter Grid.Column="1" ContentSource="Header"
                                                  Margin="6,4,12,4"
                                                  VerticalAlignment="Center"
                                                  RecognizesAccessKey="True"/>
                                <TextBlock Grid.Column="2" Text="{TemplateBinding InputGestureText}"
                                           Margin="0,4,8,4"
                                           VerticalAlignment="Center"
                                           Foreground="{DynamicResource ThemeTextFgMuted}"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource ThemeMenuItemHover}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="MenuItemSubmenuStyle" TargetType="MenuItem">
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="{DynamicResource ThemeTextFg}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="MenuItem">
                        <Grid>
                            <Border x:Name="Bd" Background="Transparent"
                                    CornerRadius="4" Margin="4,1">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="28" SharedSizeGroup="Icon"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <ContentPresenter Grid.Column="0" ContentSource="Icon"
                                                      HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"
                                                      Width="16" Height="16"/>
                                    <ContentPresenter Grid.Column="1" ContentSource="Header"
                                                      Margin="6,4,12,4"
                                                      VerticalAlignment="Center"
                                                      RecognizesAccessKey="True"/>
                                    <TextBlock Grid.Column="2" Text="&#xEAB6;"
                                               FontFamily="{x:Static local:Codicons.Font}" FontSize="10"
                                               Margin="0,0,8,0"
                                               VerticalAlignment="Center"
                                               Foreground="{DynamicResource ThemeTextFg}"/>
                                </Grid>
                            </Border>
                            <Popup x:Name="PART_Popup"
                                   IsOpen="{Binding IsSubmenuOpen, RelativeSource={RelativeSource TemplatedParent}}"
                                   Placement="Right"
                                   HorizontalOffset="-2"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   PopupAnimation="None">
                                <Border Background="{DynamicResource ThemeMenuPopupBg}"
                                        BorderBrush="{DynamicResource ThemeMenuPopupBorder}" BorderThickness="1"
                                        CornerRadius="3" Margin="0,0,6,6">
                                    <Border.Effect>
                                        <DropShadowEffect ShadowDepth="2" Opacity="0.4" BlurRadius="8"/>
                                    </Border.Effect>
                                    <StackPanel IsItemsHost="True" Margin="0,3"
                                                KeyboardNavigation.DirectionalNavigation="Cycle"/>
                                </Border>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource ThemeMenuItemHover}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="MenuItemCheckableStyle" TargetType="MenuItem" BasedOn="{StaticResource MenuItemBaseStyle}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="MenuItem">
                        <Border x:Name="Bd" Background="Transparent"
                                CornerRadius="4" Margin="4,1">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="28" SharedSizeGroup="Icon"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto" SharedSizeGroup="Shortcut"/>
                                </Grid.ColumnDefinitions>
                                <Grid Grid.Column="0">
                                    <ContentPresenter ContentSource="Icon"
                                                      HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"
                                                      Width="16" Height="16"/>
                                    <TextBlock x:Name="CheckMark" Text="&#xEAB2;"
                                               FontFamily="{x:Static local:Codicons.Font}" FontSize="14"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"
                                               Foreground="{DynamicResource ThemeTextFg}"
                                               Visibility="Collapsed"/>
                                </Grid>
                                <ContentPresenter Grid.Column="1" ContentSource="Header"
                                                  Margin="6,4,12,4"
                                                  VerticalAlignment="Center"
                                                  RecognizesAccessKey="True"/>
                                <TextBlock Grid.Column="2" Text="{TemplateBinding InputGestureText}"
                                           Margin="0,4,8,4"
                                           VerticalAlignment="Center"
                                           Foreground="{DynamicResource ThemeTextFgMuted}"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource ThemeMenuItemHover}"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="CheckMark" Property="Visibility" Value="Visible"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    <Grid>
    <DockPanel>
        <!-- Custom title bar -->
        <Grid x:Name="TitleBar" DockPanel.Dock="Top" Background="{DynamicResource ThemeChromeBrush}" Height="32"
              MouseLeftButtonDown="OnTitleBarMouseDown">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition x:Name="EditorColumn" Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Dead zone over the bottom of menu items so diagonal mouse moves
                 toward the dropdown don't accidentally graze adjacent items -->
            <Border Grid.Column="0" Height="6" VerticalAlignment="Bottom"
                    Background="Transparent" Panel.ZIndex="1"
                    WindowChrome.IsHitTestVisibleInChrome="True"/>

            <!-- App menu + File menu -->
            <Menu Grid.Column="0" Background="Transparent" VerticalAlignment="Center"
                  Margin="4,0,0,0" Padding="0"
                  FontFamily="Segoe UI" FontSize="12"
                  Foreground="{DynamicResource ThemeTextFg}"
                  WindowChrome.IsHitTestVisibleInChrome="True">
                <MenuItem Style="{StaticResource TopLevelMenuItem}"
                         ItemContainerStyle="{StaticResource MenuItemDropdownStyle}">
                    <MenuItem.Header>
                        <StackPanel Orientation="Horizontal">
                            <Viewbox Width="21" Height="21" Margin="-4,0,5,0">
                                <Canvas Width="400" Height="360">
                                    <Path Stroke="{DynamicResource ThemeTextFg}" StrokeThickness="16"
                                          StrokeLineJoin="Miter" StrokeMiterLimit="10"
                                          StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                          Data="M200,50.192 L350,310 L50,310 Z"/>
                                    <Path Stroke="{DynamicResource ThemeTextFg}" StrokeThickness="16"
                                          StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                          StrokeLineJoin="Round"
                                          Data="M150,136.795 L300,223.397 M100,223.397 L150,310 M150,310 L225,180.096"/>
                                </Canvas>
                            </Viewbox>
                            <TextBlock Text="Volt" VerticalAlignment="Center"
                                       FontWeight="SemiBold"/>
                        </StackPanel>
                    </MenuItem.Header>
                    <MenuItem x:Name="MenuSettings" Header="S_ettings" Click="OnSettings">
                        <MenuItem.Icon>
                            <TextBlock Text="&#xEB52;" FontFamily="{x:Static local:Codicons.Font}" FontSize="14" VerticalAlignment="Center"/>
                        </MenuItem.Icon>
                    </MenuItem>
                    <MenuItem Header="_About" Click="OnAbout">
                        <MenuItem.Icon>
                            <TextBlock Text="&#xEA74;" FontFamily="{x:Static local:Codicons.Font}" FontSize="14" VerticalAlignment="Center"/>
                        </MenuItem.Icon>
                    </MenuItem>
                    <Separator/>
                    <MenuItem Header="E_xit" InputGestureText="Alt+F4" Click="OnExit"/>
                </MenuItem>
                <MenuItem Header="_File" Style="{StaticResource TopLevelMenuItem}"
                         ItemContainerStyle="{StaticResource MenuItemDropdownStyle}">
                    <MenuItem x:Name="MenuSave" Header="_Save" Click="OnSave">
                        <MenuItem.Icon>
                            <TextBlock Text="&#xEB4B;" FontFamily="{x:Static local:Codicons.Font}" FontSize="14" VerticalAlignment="Center"/>
                        </MenuItem.Icon>
                    </MenuItem>
                    <MenuItem x:Name="MenuSaveAs" Header="Save _As..." Click="OnSaveAs"/>
                    <Separator/>
                    <MenuItem x:Name="MenuOpenFile" Header="_Open File" Click="OnOpen"/>
                    <MenuItem x:Name="MenuOpenFolder" Header="Open _Folder" Click="OnOpenFolder">
                        <MenuItem.Icon>
                            <TextBlock Text="&#xEAF7;" FontFamily="{x:Static local:Codicons.Font}" FontSize="14" VerticalAlignment="Center"/>
                        </MenuItem.Icon>
                    </MenuItem>
                    <MenuItem x:Name="MenuOpenWorkspace" Header="Open _Workspace" Click="OnOpenWorkspace"/>
                    <MenuItem x:Name="MenuOpenRecent" Header="Open _Recent"
                              Style="{StaticResource MenuItemSubmenuStyle}"
                              SubmenuOpened="OnOpenRecentSubmenuOpened">
                        <MenuItem Header="(empty)" IsEnabled="False"/>
                    </MenuItem>
                    <Separator/>
                    <MenuItem x:Name="MenuAddFolderToWorkspace" Header="Add Folder to _Workspace" Click="OnAddFolderToWorkspace">
                        <MenuItem.Icon>
                            <TextBlock Text="&#xEA60;" FontFamily="{x:Static local:Codicons.Font}" FontSize="12"
                                       Foreground="{DynamicResource ThemeTextFg}"
                                       VerticalAlignment="Center" HorizontalAlignment="Center"/>
                        </MenuItem.Icon>
                    </MenuItem>
                    <MenuItem x:Name="MenuSaveWorkspaceAs" Header="Save Workspace As..." Click="OnSaveWorkspaceAs" IsEnabled="False"/>
                    <MenuItem x:Name="MenuCloseWorkspace" Header="Close Workspace" Click="OnCloseWorkspace" Visibility="Collapsed">
                        <MenuItem.Icon>
                            <TextBlock Text="&#xEA76;" FontFamily="{x:Static local:Codicons.Font}" FontSize="14" VerticalAlignment="Center"/>
                        </MenuItem.Icon>
                    </MenuItem>
                    <MenuItem x:Name="MenuCloseFolder" Header="Close Folder" Click="OnCloseFolder" Visibility="Collapsed">
                        <MenuItem.Icon>
                            <TextBlock Text="&#xEA76;" FontFamily="{x:Static local:Codicons.Font}" FontSize="14" VerticalAlignment="Center"/>
                        </MenuItem.Icon>
                    </MenuItem>
                </MenuItem>
                <MenuItem Header="_Edit" Style="{StaticResource TopLevelMenuItem}"
                         ItemContainerStyle="{StaticResource MenuItemCheckableStyle}">
                    <MenuItem x:Name="MenuWordWrap" Header="_Word Wrap" IsCheckable="True" Click="OnToggleWordWrap"/>
                </MenuItem>
                <MenuItem Header="_View" Style="{StaticResource TopLevelMenuItem}"
                         ItemContainerStyle="{StaticResource MenuItemCheckableStyle}">
                    <MenuItem x:Name="MenuViewLeft" Header="_Left Panel" IsCheckable="True" Click="OnToggleLeftPanel"/>
                    <MenuItem x:Name="MenuViewRight" Header="_Right Panel" IsCheckable="True" Click="OnToggleRightPanel"/>
                    <MenuItem x:Name="MenuViewTop" Header="_Top Panel" IsCheckable="True" Click="OnToggleTopPanel"/>
                    <MenuItem x:Name="MenuViewBottom" Header="_Bottom Panel" IsCheckable="True" Click="OnToggleBottomPanel"/>
                    <Separator/>
                    <MenuItem x:Name="MenuViewIssues" Header="_Issues" IsCheckable="True" Click="OnToggleIssuesPanel"/>
                </MenuItem>
            </Menu>

            <!-- Window controls -->
            <StackPanel Grid.Column="2" Orientation="Horizontal">
                <Button Style="{StaticResource TitleBarButton}" Content="&#xE921;" Click="OnMinimize"/>
                <Button x:Name="MaxRestoreButton" Style="{StaticResource TitleBarButton}" Content="&#xE922;" Click="OnMaximizeRestore"/>
                <Button Style="{StaticResource CloseButton}" Click="OnClose"/>
            </StackPanel>
        </Grid>

        <Border DockPanel.Dock="Top" Height="1" Background="{DynamicResource ThemeBorderBrush}"/>

        <!-- Status bar -->
        <Border DockPanel.Dock="Bottom" Background="{DynamicResource ThemeChromeBrush}" Height="24">
            <DockPanel>
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Right" VerticalAlignment="Center">
                    <Border x:Name="DiagnosticsStatusHost" Height="18" MaxWidth="520"
                            Margin="0,0,8,0" Padding="7,0"
                            Background="{DynamicResource ThemeButtonHover}"
                            BorderThickness="0" CornerRadius="4"
                            VerticalAlignment="Center" ClipToBounds="True"
                            Cursor="Hand"
                            MouseLeftButtonDown="OnDiagnosticsStatusClick"
                            Visibility="Collapsed">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock x:Name="DiagnosticsStatusIcon" Text="&#xE895;"
                                       Margin="0,0,5,0"
                                       FontFamily="Segoe MDL2 Assets" FontSize="11"
                                       VerticalAlignment="Center"
                                       Foreground="{DynamicResource ThemeIconAccent}"
                                       RenderTransformOrigin="0.5,0.5"
                                       Visibility="Collapsed">
                                <TextBlock.RenderTransform>
                                    <RotateTransform x:Name="DiagnosticsSpinnerTransform"/>
                                </TextBlock.RenderTransform>
                            </TextBlock>
                            <TextBlock x:Name="DiagnosticsText" Text="" MaxWidth="420"
                                       TextTrimming="CharacterEllipsis"
                                       FontFamily="Segoe UI" FontSize="12"
                                       VerticalAlignment="Center"
                                       Foreground="{DynamicResource ThemeTextFg}"/>
                            <Grid x:Name="DiagnosticsProgressTrack" Width="44" Height="2"
                                  Margin="7,0,0,0" VerticalAlignment="Center"
                                  Background="{DynamicResource ThemeBorderBrush}"
                                  Visibility="Collapsed">
                                <Rectangle x:Name="DiagnosticsProgressFill"
                                           Width="0" HorizontalAlignment="Left"
                                           Fill="{DynamicResource ThemeIconAccent}"/>
                            </Grid>
                        </StackPanel>
                    </Border>
                    <Rectangle Width="1" Fill="{DynamicResource ThemeBorderBrush}"/>
                    <TextBlock x:Name="CaretPosText" Text="Ln 1, Col 1" Margin="8,0"
                               FontFamily="Segoe UI" FontSize="12"
                               Foreground="{DynamicResource ThemeTextFg}"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Left" VerticalAlignment="Center">
                    <TextBlock x:Name="FileTypeText" Text="Plain Text" Margin="8,0"
                               FontFamily="Segoe UI" FontSize="12"
                               Foreground="{DynamicResource ThemeTextFg}"
                               Cursor="Hand"
                               MouseLeftButtonDown="OnFileTypeClick"/>
                    <Rectangle Width="1" Fill="{DynamicResource ThemeBorderBrush}"/>
                    <TextBlock x:Name="EncodingText" Text="UTF-8" Margin="8,0"
                               FontFamily="Segoe UI" FontSize="12"
                               Foreground="{DynamicResource ThemeTextFg}"/>
                    <Rectangle Width="1" Fill="{DynamicResource ThemeBorderBrush}"/>
                    <TextBlock x:Name="LineEndingText" Text="LF" Margin="8,0"
                               FontFamily="Segoe UI" FontSize="12"
                               Foreground="{DynamicResource ThemeTextFg}"/>
                    <Rectangle Width="1" Fill="{DynamicResource ThemeBorderBrush}"/>
                    <TextBlock x:Name="CharCountText" Text="0 Characters" Margin="8,0"
                               FontFamily="Segoe UI" FontSize="12"
                               Foreground="{DynamicResource ThemeTextFg}"/>
                </StackPanel>
            </DockPanel>
        </Border>
        <Border DockPanel.Dock="Bottom" Height="1" Background="{DynamicResource ThemeBorderBrush}"/>

        <local:PanelShell x:Name="Shell"
                          WindowChrome.IsHitTestVisibleInChrome="True"/>
    </DockPanel>

    <!-- Editor center content (assigned to Shell.CenterContent in code-behind) -->
    <Grid x:Name="EditorColumnGrid" Visibility="Collapsed">
        <Grid x:Name="EditorLayoutHost" ClipToBounds="True"/>
        <local:FindBar x:Name="FindBarControl" />
    </Grid>

    <!-- Command palette overlay -->
    <local:CommandPalette x:Name="CmdPalette" />
    </Grid>
</Window>
