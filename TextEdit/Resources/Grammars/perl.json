{
  "name": "Perl",
  "extensions": [".pl", ".pm", ".t", ".cgi"],
  "blockComments": [
    {
      "start": "^=\\w+",
      "end": "^=cut\\b",
      "scope": "comment"
    },
    {
      "start": "^__(?:DATA|END)__$",
      "scope": "comment"
    }
  ],
  "heredoc": {
    "pattern": "<<~?\\s*(?:'(\\w+)'|\"(\\w+)\"|(\\w+))",
    "noInterpolationGroup": 1
  },
  "interpolation": {
    "quotes": "\"",
    "variablePattern": "(?<!\\\\)[\\$@](?:\\{[\\w:]+\\}|[\\w:]+)",
    "escapePattern": "\\\\(?:[abefnrt\\\\'\"]|0[0-7]*|x[0-9a-fA-F]{1,2}|u[0-9a-fA-F]{4}|N\\{[^}]+\\}|.)"
  },
  "rules": [
    {
      "pattern": "(?:\"(?:\\\\.|[^\"])*\"|'(?:\\\\.|[^'])*'|`(?:\\\\.|[^`])*`)",
      "scope": "string"
    },
    {
      "pattern": "#.*$",
      "scope": "comment"
    },
    {
      "pattern": "(?<![\\w$@%])\\b(?:use|no|require|package|sub|my|our|local|return|if|elsif|else|unless|while|until|for|foreach|do|last|next|redo|goto|die|warn|print|say|chomp|chop|push|pop|shift|unshift|splice|split|join|sort|reverse|map|grep|defined|undef|exists|delete|keys|values|each|length|scalar|ref|bless|tie|untie|open|close|read|write|seek|tell|eof|binmode|eval|BEGIN|END|INIT|CHECK|UNITCHECK|DESTROY|AUTOLOAD|__FILE__|__LINE__|__PACKAGE__|__SUB__|__DATA__|__END__)\\b",
      "scope": "keyword"
    },
    {
      "pattern": "(?<=\\bsub\\s)\\w+",
      "scope": "function"
    },
    {
      "pattern": "\\b\\w+(?=\\s*\\()",
      "scope": "function"
    },
    {
      "pattern": "&\\w[\\w:]*",
      "scope": "function"
    },
    {
      "pattern": "(?<=->)\\w+",
      "scope": "function"
    },
    {
      "pattern": "(?<=\\b(?:use|require|package)\\s)\\w+(?:::\\w+)*",
      "scope": "type"
    },
    {
      "pattern": "\\b\\w+(?=::)",
      "scope": "type"
    },
    {
      "pattern": "\\b[A-Z]\\w*(?=->)",
      "scope": "type"
    },
    {
      "pattern": "\\w+(?=\\s*=>)",
      "scope": "hashkey"
    },
    {
      "pattern": "(?<=\\{)\\w+(?=\\})",
      "scope": "hashkey"
    },
    {
      "pattern": "\\$(?:#[\\w:]+|\\{[\\w:]+\\}|[\\w:]+|\\d+|[\"'\\\\/$;!@&`+\\-\\[\\]<>?^~])",
      "scope": "variable"
    },
    {
      "pattern": "[@%](?:\\{[\\w:]+\\}|[\\w:]+)",
      "scope": "variable"
    },
    {
      "pattern": "(?:\\b|(?<=\\s))(?:=>|->|=~|!~|&&|\\|\\||//|\\.\\.|\\.\\.\\.)",
      "scope": "operator"
    },
    {
      "pattern": "(?<!\\.)\\b(?:0[xX][0-9a-fA-F_]+|0[bB][01_]+|0[0-7_]+|[0-9][0-9_]*(?:\\.[0-9_]+)?(?:[eE][+-]?[0-9_]+)?)\\b",
      "scope": "number"
    },
    {
      "pattern": "(?:qw|qq|q)\\s*[({\\[/].*?[)}\\]/]",
      "scope": "string"
    },
    {
      "pattern": "(?:s|tr|y)([^\\w\\s])(?:\\\\.|(?!\\1).)*\\1(?:\\\\.|(?!\\1).)*\\1[gimsxce]*",
      "scope": "regex"
    },
    {
      "pattern": "(?:m|qr)([^\\w\\s])(?:\\\\.|(?!\\1).)*\\1[gimsxce]*",
      "scope": "regex"
    },
    {
      "pattern": "/(?:\\\\/|[^/\\n])+/[gimsxce]*",
      "scope": "regex"
    }
  ]
}
