<Window x:Class="TextEdit.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Settings" Height="400" Width="550"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">
    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="32" ResizeBorderThickness="0"
                      GlassFrameThickness="-1"
                      UseAeroCaptionButtons="False"/>
    </WindowChrome.WindowChrome>
    <Window.Resources>
        <Style x:Key="NavButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding" Value="16,10"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="{DynamicResource ThemeButtonFg}"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource ThemeNavHover}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="NavButtonActive" TargetType="Button" BasedOn="{StaticResource NavButton}">
            <Setter Property="Background" Value="{DynamicResource ThemeNavActive}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
        <Style x:Key="SettingLabel" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="{DynamicResource ThemeTextFg}"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style x:Key="SectionHeader" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{DynamicResource ThemeTextFgStrong}"/>
            <Setter Property="Margin" Value="0,0,0,16"/>
        </Style>

        <!-- Themed ComboBox -->
        <Style x:Key="ThemedComboBoxToggle" TargetType="ToggleButton">
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="IsTabStop" Value="False"/>
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="ClickMode" Value="Press"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="Bd" Background="{DynamicResource ThemeNavActive}"
                                BorderBrush="{DynamicResource ThemeBorderBrush}" BorderThickness="1"
                                CornerRadius="3">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="24"/>
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="1">
                                    <TextBlock Text="&#xE70D;" FontFamily="Segoe MDL2 Assets" FontSize="9"
                                               Foreground="{DynamicResource ThemeTextFg}"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource ThemeNavHover}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="Foreground" Value="{DynamicResource ThemeTextFg}"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton Style="{StaticResource ThemedComboBoxToggle}"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"/>
                            <ContentPresenter IsHitTestVisible="False"
                                              Content="{TemplateBinding SelectionBoxItem}"
                                              ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                              Margin="8,0,28,0"
                                              VerticalAlignment="Center"
                                              HorizontalAlignment="Left"/>
                            <Popup IsOpen="{TemplateBinding IsDropDownOpen}"
                                   Placement="Bottom" Focusable="False"
                                   AllowsTransparency="True" PopupAnimation="None">
                                <Border Background="{DynamicResource ThemeMenuPopupBg}"
                                        BorderBrush="{DynamicResource ThemeMenuPopupBorder}"
                                        BorderThickness="1" CornerRadius="2"
                                        MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}"
                                        Margin="0,1,4,4" Padding="0,2">
                                    <Border.Effect>
                                        <DropShadowEffect ShadowDepth="1" Opacity="0.2" BlurRadius="4"/>
                                    </Border.Effect>
                                    <ScrollViewer MaxHeight="200" VerticalScrollBarVisibility="Auto">
                                        <StackPanel IsItemsHost="True"
                                                    KeyboardNavigation.DirectionalNavigation="Contained"/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="ComboBoxItem">
            <Setter Property="Foreground" Value="{DynamicResource ThemeTextFg}"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="Bd" Background="Transparent" Padding="10,5">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource ThemeMenuItemHover}"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource ThemeNavActive}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Themed Slider -->
        <Style x:Key="SliderThumb" TargetType="Thumb">
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Thumb">
                        <Ellipse x:Name="Dot" Width="14" Height="14"
                                 Fill="{DynamicResource ThemeTextFg}"
                                 Stroke="{DynamicResource ThemeBorderBrush}" StrokeThickness="1"/>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Dot" Property="Fill" Value="{DynamicResource ThemeTextFgStrong}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="Slider">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Slider">
                        <Grid>
                            <Border Height="3" VerticalAlignment="Center" CornerRadius="1.5"
                                    Background="{DynamicResource ThemeNavActive}"/>
                            <Track x:Name="PART_Track">
                                <Track.Thumb>
                                    <Thumb Style="{StaticResource SliderThumb}"/>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Themed action buttons (OK/Cancel) -->
        <Style x:Key="ActionButton" TargetType="Button">
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="{DynamicResource ThemeTextFg}"/>
            <Setter Property="Background" Value="{DynamicResource ThemeNavActive}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="{DynamicResource ThemeBorderBrush}"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="3" Padding="12,4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource ThemeNavHover}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource ThemeButtonHover}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    <DockPanel>
        <!-- Custom title bar -->
        <Grid DockPanel.Dock="Top" Background="{DynamicResource ThemeChromeBrush}" Height="32">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0" Text="Settings"
                       VerticalAlignment="Center" Margin="12,0,0,0"
                       FontFamily="Segoe UI" FontSize="12"
                       Foreground="{DynamicResource ThemeTextFg}"
                       IsHitTestVisible="False"/>

            <Button Grid.Column="1" Style="{StaticResource CloseButton}"
                    Content="&#xE8BB;" Click="OnCancel"/>
        </Grid>

        <Border DockPanel.Dock="Top" Height="1" Background="{DynamicResource ThemeBorderBrush}"/>

        <!-- Main content area -->
        <Grid Background="{DynamicResource ThemeContentBg}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="160"/>
                <ColumnDefinition Width="1"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Left nav -->
            <Border Grid.Column="0" Background="{DynamicResource ThemeNavBg}">
                <StackPanel>
                    <Button x:Name="NavBehaviour" Content="Behaviour"
                            Style="{StaticResource NavButtonActive}"
                            Click="OnNavBehaviour"/>
                    <Button x:Name="NavAppearance" Content="Appearance"
                            Style="{StaticResource NavButton}"
                            Click="OnNavAppearance"/>
                </StackPanel>
            </Border>

            <!-- Separator -->
            <Border Grid.Column="1" Background="{DynamicResource ThemeBorderBrush}"/>

            <!-- Right content area -->
            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="1"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Behaviour section -->
                <ScrollViewer x:Name="BehaviourScroller" Grid.Row="0"
                              Template="{StaticResource ThemedScrollViewer}"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <StackPanel x:Name="BehaviourPanel" Margin="24,20">
                        <TextBlock Text="Behaviour" Style="{StaticResource SectionHeader}"/>

                        <TextBlock Text="Tab size" Style="{StaticResource SettingLabel}" Margin="0,0,0,4"/>
                        <ComboBox x:Name="TabSizeBox" Width="70" Height="26"
                                  HorizontalAlignment="Left" Margin="0,0,0,16"
                                  VerticalContentAlignment="Center" FontSize="13">
                            <ComboBoxItem Content="2"/>
                            <ComboBoxItem Content="4"/>
                            <ComboBoxItem Content="8"/>
                        </ComboBox>

                        <TextBlock Text="Caret style" Style="{StaticResource SettingLabel}" Margin="0,0,0,4"/>
                        <ComboBox x:Name="CaretStyleBox" Width="100" Height="26"
                                  HorizontalAlignment="Left" Margin="0,0,0,16"
                                  VerticalContentAlignment="Center" FontSize="13">
                            <ComboBoxItem Content="Bar"/>
                            <ComboBoxItem Content="Block"/>
                        </ComboBox>

                        <TextBlock Text="Caret blink" Style="{StaticResource SettingLabel}" Margin="0,0,0,4"/>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                            <Slider x:Name="CaretBlinkSlider" Width="180" Minimum="0" Maximum="1000"
                                    TickFrequency="50" IsSnapToTickEnabled="True"
                                    VerticalAlignment="Center"
                                    ValueChanged="OnCaretBlinkSliderChanged"/>
                            <TextBlock x:Name="CaretBlinkLabel" Style="{StaticResource SettingLabel}"
                                       Margin="10,0,0,0" Width="50"/>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>

                <!-- Appearance section -->
                <ScrollViewer x:Name="AppearanceScroller" Grid.Row="0"
                              Template="{StaticResource ThemedScrollViewer}"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled"
                              Visibility="Collapsed">
                    <StackPanel x:Name="AppearancePanel" Margin="24,20">
                        <TextBlock Text="Appearance" Style="{StaticResource SectionHeader}"/>

                        <TextBlock Text="Theme" Style="{StaticResource SettingLabel}" Margin="0,0,0,4"/>
                        <ComboBox x:Name="ColorThemeBox" Width="200" Height="26"
                                  HorizontalAlignment="Left" Margin="0,0,0,16"
                                  VerticalContentAlignment="Center" FontSize="13"/>

                        <TextBlock Text="Font" Style="{StaticResource SettingLabel}" Margin="0,0,0,4"/>
                        <ComboBox x:Name="FontFamilyBox" Width="200" Height="26"
                                  HorizontalAlignment="Left" Margin="0,0,0,16"
                                  VerticalContentAlignment="Center" FontSize="13"/>

                        <TextBlock Text="Font size" Style="{StaticResource SettingLabel}" Margin="0,0,0,4"/>
                        <ComboBox x:Name="FontSizeBox" Width="80" Height="26"
                                  HorizontalAlignment="Left" Margin="0,0,0,16"
                                  VerticalContentAlignment="Center" FontSize="13"/>

                        <TextBlock Text="Font weight" Style="{StaticResource SettingLabel}" Margin="0,0,0,4"/>
                        <ComboBox x:Name="FontWeightBox" Width="140" Height="26"
                                  HorizontalAlignment="Left" Margin="0,0,0,16"
                                  VerticalContentAlignment="Center" FontSize="13"/>
                    </StackPanel>
                </ScrollViewer>

                <!-- Bottom bar -->
                <Border Grid.Row="1" Background="{DynamicResource ThemeBorderBrush}"/>
                <StackPanel Grid.Row="2" Orientation="Horizontal"
                            HorizontalAlignment="Right" Margin="16,12">
                    <Button Content="OK" Width="75" Height="28" Margin="0,0,8,0"
                            Style="{StaticResource ActionButton}"
                            Click="OnOK" IsDefault="True"/>
                    <Button Content="Cancel" Width="75" Height="28"
                            Style="{StaticResource ActionButton}"
                            Click="OnCancel" IsCancel="True"/>
                </StackPanel>
            </Grid>
        </Grid>
    </DockPanel>
</Window>
