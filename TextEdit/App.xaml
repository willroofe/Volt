<Application x:Class="TextEdit.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:TextEdit"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <!-- Light theme defaults (overwritten at runtime by ThemeManager) -->
        <SolidColorBrush x:Key="ThemeChromeBrush" Color="#E8E8E8"/>
        <SolidColorBrush x:Key="ThemeBorderBrush" Color="#D0D0D0"/>
        <SolidColorBrush x:Key="ThemeContentBg" Color="White"/>
        <SolidColorBrush x:Key="ThemeTextFg" Color="#111111"/>
        <SolidColorBrush x:Key="ThemeTextFgStrong" Color="#222222"/>
        <SolidColorBrush x:Key="ThemeTextFgMuted" Color="#888888"/>
        <SolidColorBrush x:Key="ThemeButtonFg" Color="#333333"/>
        <SolidColorBrush x:Key="ThemeButtonHover" Color="#D0D0D0"/>
        <SolidColorBrush x:Key="ThemeMenuPopupBg" Color="White"/>
        <SolidColorBrush x:Key="ThemeMenuPopupBorder" Color="#D0D0D0"/>
        <SolidColorBrush x:Key="ThemeMenuItemHover" Color="#E0E0E0"/>
        <SolidColorBrush x:Key="ThemeNavBg" Color="#F0F0F0"/>
        <SolidColorBrush x:Key="ThemeNavActive" Color="#D8D8D8"/>
        <SolidColorBrush x:Key="ThemeNavHover" Color="#E0E0E0"/>
        <SolidColorBrush x:Key="ThemeScrollBg" Color="#E0E0E0"/>
        <SolidColorBrush x:Key="ThemeScrollThumb" Color="#C0C0C0"/>
        <SolidColorBrush x:Key="ThemeScrollThumbHover" Color="#A0A0A0"/>

        <!-- Scrollbar thumb (shared by both orientations) -->
        <Style x:Key="ScrollBarThumb" TargetType="Thumb">
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="IsTabStop" Value="False"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Thumb">
                        <Border x:Name="Bd" Background="{DynamicResource ThemeScrollThumb}"
                                CornerRadius="0"/>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background"
                                        Value="{DynamicResource ThemeScrollThumbHover}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Invisible repeat button for the track area above/below the thumb -->
        <Style x:Key="ScrollBarTrackButton" TargetType="RepeatButton">
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="IsTabStop" Value="False"/>
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RepeatButton">
                        <Border Background="Transparent"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Arrow repeat button (top/bottom/left/right) -->
        <Style x:Key="ScrollBarArrowButton" TargetType="RepeatButton">
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="IsTabStop" Value="False"/>
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RepeatButton">
                        <Border Background="{DynamicResource ThemeScrollBg}" Height="0" Width="0"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Vertical ScrollBar -->
        <ControlTemplate x:Key="VerticalScrollBar" TargetType="ScrollBar">
            <Grid>
                <Border Background="{DynamicResource ThemeScrollBg}"/>
                <Track x:Name="PART_Track" IsDirectionReversed="True">
                    <Track.DecreaseRepeatButton>
                        <RepeatButton Style="{StaticResource ScrollBarTrackButton}"
                                      Command="ScrollBar.PageUpCommand"/>
                    </Track.DecreaseRepeatButton>
                    <Track.Thumb>
                        <Thumb Style="{StaticResource ScrollBarThumb}"
                               Margin="2,0"/>
                    </Track.Thumb>
                    <Track.IncreaseRepeatButton>
                        <RepeatButton Style="{StaticResource ScrollBarTrackButton}"
                                      Command="ScrollBar.PageDownCommand"/>
                    </Track.IncreaseRepeatButton>
                </Track>
            </Grid>
        </ControlTemplate>

        <!-- Horizontal ScrollBar -->
        <ControlTemplate x:Key="HorizontalScrollBar" TargetType="ScrollBar">
            <Grid>
                <Border Background="{DynamicResource ThemeScrollBg}"/>
                <Track x:Name="PART_Track">
                    <Track.DecreaseRepeatButton>
                        <RepeatButton Style="{StaticResource ScrollBarTrackButton}"
                                      Command="ScrollBar.PageLeftCommand"/>
                    </Track.DecreaseRepeatButton>
                    <Track.Thumb>
                        <Thumb Style="{StaticResource ScrollBarThumb}"
                               Margin="0,2"/>
                    </Track.Thumb>
                    <Track.IncreaseRepeatButton>
                        <RepeatButton Style="{StaticResource ScrollBarTrackButton}"
                                      Command="ScrollBar.PageRightCommand"/>
                    </Track.IncreaseRepeatButton>
                </Track>
            </Grid>
        </ControlTemplate>

        <!-- ScrollBar style that picks the right template by orientation -->
        <Style TargetType="ScrollBar">
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Style.Triggers>
                <Trigger Property="Orientation" Value="Vertical">
                    <Setter Property="Width" Value="14"/>
                    <Setter Property="Template" Value="{StaticResource VerticalScrollBar}"/>
                </Trigger>
                <Trigger Property="Orientation" Value="Horizontal">
                    <Setter Property="Height" Value="14"/>
                    <Setter Property="Template" Value="{StaticResource HorizontalScrollBar}"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <!-- ScrollViewer with themed corner -->
        <ControlTemplate x:Key="ThemedScrollViewer" TargetType="ScrollViewer">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <ScrollContentPresenter Grid.Column="0" Grid.Row="0"
                                        CanContentScroll="{TemplateBinding CanContentScroll}"/>
                <ScrollBar x:Name="PART_VerticalScrollBar"
                           Grid.Column="1" Grid.Row="0"
                           Orientation="Vertical"
                           Value="{TemplateBinding VerticalOffset}"
                           Maximum="{TemplateBinding ScrollableHeight}"
                           ViewportSize="{TemplateBinding ViewportHeight}"
                           Visibility="{TemplateBinding ComputedVerticalScrollBarVisibility}"/>
                <ScrollBar x:Name="PART_HorizontalScrollBar"
                           Grid.Column="0" Grid.Row="1"
                           Orientation="Horizontal"
                           Value="{TemplateBinding HorizontalOffset}"
                           Maximum="{TemplateBinding ScrollableWidth}"
                           ViewportSize="{TemplateBinding ViewportWidth}"
                           Visibility="{TemplateBinding ComputedHorizontalScrollBarVisibility}"/>
                <Rectangle Grid.Column="1" Grid.Row="1"
                           Fill="{DynamicResource ThemeScrollBg}"/>
            </Grid>
        </ControlTemplate>
    </Application.Resources>
</Application>
