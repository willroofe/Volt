<Window x:Class="TextEdit.ThemedMessageBox"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="TextEdit"
        Width="420" Height="170"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False">
    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="32" ResizeBorderThickness="0"
                      GlassFrameThickness="-1"
                      UseAeroCaptionButtons="False"/>
    </WindowChrome.WindowChrome>
    <Window.Resources>
        <Style x:Key="DialogButton" TargetType="Button">
            <Setter Property="MinWidth" Value="80"/>
            <Setter Property="Margin" Value="4,0,0,0"/>
            <Setter Property="Padding" Value="12,6,12,6"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="{DynamicResource ThemeButtonFg}"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{DynamicResource ThemeContentBg}"
                                BorderBrush="{DynamicResource ThemeMenuPopupBorder}"
                                BorderThickness="1" CornerRadius="3"
                                Padding="{TemplateBinding Padding}"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource ThemeButtonHover}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    <DockPanel Background="{DynamicResource ThemeContentBg}">
        <!-- Title bar -->
        <Grid DockPanel.Dock="Top" Background="{DynamicResource ThemeChromeBrush}" Height="32">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock x:Name="TitleText" Grid.Column="0" Text="TextEdit"
                       VerticalAlignment="Center" Margin="12,0,0,0"
                       FontFamily="Segoe UI" FontSize="12"
                       Foreground="{DynamicResource ThemeTextFg}"
                       IsHitTestVisible="False"/>
            <Button Grid.Column="1" Style="{StaticResource CloseButton}"
                    Content="&#xE8BB;" Click="OnClose"/>
        </Grid>

        <Border DockPanel.Dock="Top" Height="1" Background="{DynamicResource ThemeBorderBrush}"/>

        <!-- Content -->
        <Grid Margin="24,20,24,20">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock x:Name="MessageText" Grid.Row="0"
                       FontFamily="Segoe UI" FontSize="13"
                       Foreground="{DynamicResource ThemeTextFg}"
                       TextWrapping="Wrap"
                       VerticalAlignment="Top"/>

            <StackPanel x:Name="ButtonPanel" Grid.Row="1"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Margin="0,16,0,0"/>
        </Grid>
    </DockPanel>
</Window>
