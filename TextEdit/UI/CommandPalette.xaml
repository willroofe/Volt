<UserControl x:Class="TextEdit.CommandPalette"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Visibility="Collapsed">
    <Grid>
        <!-- Overlay (semi-transparent dark background) -->
        <Border x:Name="_overlay"
                Background="#80000000"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Stretch"
                MouseLeftButtonDown="OnOverlayClick"/>

        <!-- Panel -->
        <Border x:Name="_panel"
                Width="420"
                CornerRadius="6"
                BorderThickness="1"
                HorizontalAlignment="Center"
                VerticalAlignment="Top"
                Margin="0,50,0,0"
                Background="{DynamicResource ThemeMenuPopupBg}"
                BorderBrush="{DynamicResource ThemeMenuPopupBorder}">
            <Border.Effect>
                <DropShadowEffect BlurRadius="16" Opacity="0.3" ShadowDepth="2"/>
            </Border.Effect>
            <StackPanel>
                <!-- Input area -->
                <Border Background="{DynamicResource ThemeContentBg}">
                    <DockPanel Margin="10,8,10,8">
                        <TextBlock x:Name="_filterPrefix"
                                   DockPanel.Dock="Left"
                                   VerticalAlignment="Center"
                                   FontFamily="Segoe UI"
                                   FontSize="14"
                                   Foreground="{DynamicResource ThemeTextFgMuted}"/>
                        <TextBox x:Name="_filterInput"
                                 BorderThickness="0"
                                 FontFamily="Segoe UI"
                                 FontSize="14"
                                 Padding="0"
                                 VerticalContentAlignment="Center"
                                 Background="Transparent"
                                 Foreground="{DynamicResource ThemeTextFg}"
                                 CaretBrush="{DynamicResource ThemeTextFg}"
                                 TextChanged="OnInputTextChanged"/>
                    </DockPanel>
                </Border>

                <!-- Separator -->
                <Border Height="1" Background="{DynamicResource ThemeMenuPopupBorder}"/>

                <!-- List -->
                <ListBox x:Name="_commandList"
                         BorderThickness="0"
                         MaxHeight="320"
                         Padding="0"
                         FocusVisualStyle="{x:Null}"
                         Focusable="False"
                         Background="{DynamicResource ThemeMenuPopupBg}"/>

                <!-- No results message -->
                <TextBlock x:Name="_noResults"
                           Text="No matching commands"
                           FontFamily="Segoe UI"
                           FontSize="13"
                           Margin="12,8,12,8"
                           Visibility="Collapsed"
                           Foreground="{DynamicResource ThemeTextFgMuted}"/>

                <!-- Placeholder -->
                <TextBlock x:Name="_placeholder"
                           Text="Type to search..."
                           FontFamily="Segoe UI"
                           FontSize="13"
                           FontStyle="Italic"
                           Margin="12,8,12,8"
                           Visibility="Collapsed"
                           Foreground="{DynamicResource ThemeTextFgMuted}"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
